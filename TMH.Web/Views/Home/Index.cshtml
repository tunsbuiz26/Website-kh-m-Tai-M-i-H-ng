@{
    ViewBag.Title = "Phòng Khám Tai Mũi Họng";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <style>
        /* ===== HERO ===== */
        .hero {
            display: grid;
            grid-template-columns: 1fr 1fr;
            min-height: 480px;
            background: linear-gradient(135deg,#f0f8ff 0%,#fff 60%);
            padding: 60px 40px 50px;
            gap: 40px;
            align-items: center;
            position: relative;
            overflow: hidden;
        }

            .hero::before {
                content: '';
                position: absolute;
                right: -100px;
                top: -100px;
                width: 400px;
                height: 400px;
                border-radius: 50%;
                background: rgba(26,111,168,0.06);
                pointer-events: none;
            }

            .hero::after {
                content: '';
                position: absolute;
                right: 80px;
                bottom: -60px;
                width: 200px;
                height: 200px;
                border-radius: 50%;
                background: rgba(201,162,39,0.08);
                pointer-events: none;
            }

        .hero-tag {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            background: #fdf3d7;
            border: 1px solid rgba(201,162,39,0.3);
            border-radius: 20px;
            padding: 4px 12px;
            font-size: 11px;
            font-weight: 500;
            color: #c9a227;
            margin-bottom: 18px;
        }

            .hero-tag::before {
                content: '✦';
                font-size: 9px;
            }

        .hero-title {
            font-family: 'Crimson Pro',serif;
            font-size: 40px;
            font-weight: 600;
            color: #0a4d7c;
            line-height: 1.2;
            margin-bottom: 16px;
        }

            .hero-title em {
                color: #c9a227;
                font-style: normal;
            }

        .hero-desc {
            font-size: 14px;
            color: #3a5a72;
            line-height: 1.7;
            margin-bottom: 28px;
            max-width: 420px;
        }

        .hero-btns {
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
        }

        .btn-hero-primary {
            height: 44px;
            padding: 0 24px;
            background: #0a4d7c;
            color: #fff;
            border: none;
            border-radius: 10px;
            font-size: 14px;
            font-weight: 500;
            cursor: pointer;
            font-family: 'DM Sans',sans-serif;
            transition: background .15s;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
        }

            .btn-hero-primary:hover {
                background: #1a6fa8;
            }

        .btn-hero-secondary {
            height: 44px;
            padding: 0 24px;
            background: #fdf3d7;
            color: #c9a227;
            border: 1px solid rgba(201,162,39,0.4);
            border-radius: 10px;
            font-size: 14px;
            font-weight: 500;
            cursor: pointer;
            font-family: 'DM Sans',sans-serif;
            transition: background .15s;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
        }

            .btn-hero-secondary:hover {
                background: #f5e9b8;
            }

        .hero-stats {
            display: flex;
            gap: 24px;
            margin-top: 28px;
        }

        .stat-item {
            text-align: center;
        }

        .stat-num {
            font-family: 'Crimson Pro',serif;
            font-size: 26px;
            font-weight: 600;
            color: #0a4d7c;
        }

        .stat-lbl {
            font-size: 11px;
            color: #7a9bb0;
            margin-top: 2px;
        }

        .stat-div {
            width: 1px;
            background: #d4e8f5;
            align-self: stretch;
        }

        /* ===== APPOINTMENT CARD ===== */
        .hero-card {
            background: #fff;
            border: 1px solid #d4e8f5;
            border-radius: 16px;
            padding: 24px;
            box-shadow: 0 8px 32px rgba(10,77,124,0.08);
        }

        .card-head-title {
            font-size: 15px;
            font-weight: 500;
            color: #0a4d7c;
            margin-bottom: 4px;
        }

        .card-head-sub {
            font-size: 12px;
            color: #7a9bb0;
            margin-bottom: 20px;
        }

        .appt-form-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px;
            margin-bottom: 12px;
        }

        .appt-form-full {
            margin-bottom: 12px;
        }

        .appt-label {
            font-size: 11px;
            font-weight: 500;
            color: #3a5a72;
            margin-bottom: 5px;
            display: block;
            text-transform: uppercase;
            letter-spacing: .04em;
        }

        .appt-input {
            width: 100%;
            height: 38px;
            border: 1px solid #d4e8f5;
            border-radius: 8px;
            padding: 0 12px;
            font-size: 13px;
            color: #0d2d44;
            background: #fff;
            outline: none;
            font-family: 'DM Sans',sans-serif;
            transition: border-color .15s;
        }

            .appt-input:focus {
                border-color: #1a6fa8;
                box-shadow: 0 0 0 3px rgba(26,111,168,0.1);
            }

        .appt-select {
            width: 100%;
            height: 38px;
            border: 1px solid #d4e8f5;
            border-radius: 8px;
            padding: 0 12px;
            font-size: 13px;
            color: #0d2d44;
            background: #fff;
            outline: none;
            font-family: 'DM Sans',sans-serif;
        }

        .btn-appt {
            width: 100%;
            height: 40px;
            background: #0a4d7c;
            color: #fff;
            border: none;
            border-radius: 8px;
            font-size: 14px;
            font-weight: 500;
            cursor: pointer;
            font-family: 'DM Sans',sans-serif;
            margin-top: 4px;
            transition: background .15s;
        }

            .btn-appt:hover {
                background: #1a6fa8;
            }

        .appt-note {
            text-align: center;
            font-size: 11px;
            color: #7a9bb0;
            margin-top: 8px;
        }

            .appt-note span {
                color: #c9a227;
                font-weight: 500;
            }

        /* ===== SECTIONS ===== */
        .section {
            padding: 52px 40px;
        }

        .section-tag {
            display: inline-block;
            background: #e8f4fd;
            color: #1a6fa8;
            font-size: 11px;
            font-weight: 500;
            padding: 4px 12px;
            border-radius: 20px;
            letter-spacing: .05em;
            text-transform: uppercase;
            margin-bottom: 10px;
        }

        .section-title {
            font-family: 'Crimson Pro',serif;
            font-size: 28px;
            font-weight: 600;
            color: #0a4d7c;
            margin-bottom: 6px;
        }

        .section-sub {
            font-size: 13px;
            color: #7a9bb0;
            margin-bottom: 32px;
        }

        /* ===== SERVICES ===== */
        .services-grid {
            display: grid;
            grid-template-columns: repeat(4,1fr);
            gap: 16px;
        }

        .svc-card {
            background: #fff;
            border: 1px solid #d4e8f5;
            border-radius: 14px;
            padding: 20px 18px;
            cursor: pointer;
            transition: border-color .2s,transform .15s;
            position: relative;
            overflow: hidden;
        }

            .svc-card::before {
                content: '';
                position: absolute;
                top: 0;
                left: 0;
                right: 0;
                height: 3px;
                background: #0a4d7c;
                opacity: 0;
                transition: opacity .2s;
            }

            .svc-card:hover {
                border-color: #1a6fa8;
                transform: translateY(-2px);
            }

                .svc-card:hover::before {
                    opacity: 1;
                }

        .svc-icon {
            width: 44px;
            height: 44px;
            border-radius: 12px;
            background: #e8f4fd;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 14px;
        }

        .svc-name {
            font-size: 14px;
            font-weight: 500;
            color: #0a4d7c;
            margin-bottom: 6px;
        }

        .svc-desc {
            font-size: 12px;
            color: #7a9bb0;
            line-height: 1.55;
        }

        .svc-badge {
            display: inline-block;
            margin-top: 10px;
            font-size: 10px;
            font-weight: 500;
            padding: 2px 8px;
            border-radius: 10px;
            background: #fdf3d7;
            color: #c9a227;
        }

        /* ===== SYMPTOM ===== */
        .symptom-section {
            background: #fffbef;
            border-top: 1px solid rgba(201,162,39,0.2);
            border-bottom: 1px solid rgba(201,162,39,0.2);
            padding: 44px 40px;
        }

        .symptom-grid {
            display: grid;
            grid-template-columns: repeat(4,1fr);
            gap: 12px;
            margin-top: 24px;
        }

        .sym-card {
            background: #fff;
            border: 1px solid rgba(201,162,39,0.25);
            border-radius: 12px;
            padding: 16px 14px;
            cursor: pointer;
            text-align: center;
            transition: border-color .2s,transform .15s;
        }

            .sym-card:hover {
                border-color: #c9a227;
                transform: translateY(-2px);
            }

        .sym-emoji {
            font-size: 28px;
            margin-bottom: 8px;
        }

        .sym-name {
            font-size: 13px;
            font-weight: 500;
            color: #0a4d7c;
            margin-bottom: 4px;
        }

        .sym-desc {
            font-size: 11px;
            color: #7a9bb0;
            line-height: 1.4;
        }

        /* ===== DOCTORS ===== */
        .section-alt {
            background: #f0f8ff;
        }

        .doctors-grid {
            display: grid;
            grid-template-columns: repeat(3,1fr);
            gap: 20px;
        }

        .doc-card {
            background: #fff;
            border: 1px solid #d4e8f5;
            border-radius: 14px;
            overflow: hidden;
            transition: box-shadow .2s;
        }

            .doc-card:hover {
                box-shadow: 0 8px 24px rgba(10,77,124,0.1);
            }

        .doc-avatar {
            height: 120px;
            background: linear-gradient(135deg,#e8f4fd,#f0f8ff);
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
        }

        .avatar-circle {
            width: 72px;
            height: 72px;
            border-radius: 50%;
            background: #0a4d7c;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Crimson Pro',serif;
            font-size: 24px;
            font-weight: 600;
            color: #fff;
            border: 3px solid rgba(255,255,255,0.5);
        }

        .doc-avail {
            position: absolute;
            bottom: 10px;
            right: 12px;
            background: #fff;
            border: 1px solid #c9f0d8;
            border-radius: 10px;
            padding: 3px 8px;
            font-size: 10px;
            color: #2d7a52;
            font-weight: 500;
            display: flex;
            align-items: center;
            gap: 4px;
        }

            .doc-avail::before {
                content: '';
                width: 6px;
                height: 6px;
                border-radius: 50%;
                background: #3aaa6a;
            }

        .doc-body {
            padding: 16px;
        }

        .doc-name {
            font-size: 14px;
            font-weight: 500;
            color: #0a4d7c;
            margin-bottom: 3px;
        }

        .doc-spec {
            font-size: 12px;
            color: #c9a227;
            font-weight: 500;
            margin-bottom: 8px;
        }

        .doc-info {
            font-size: 11px;
            color: #7a9bb0;
            line-height: 1.6;
        }

        .btn-book {
            width: 100%;
            height: 34px;
            background: #e8f4fd;
            color: #0a4d7c;
            border: 1px solid #d4e8f5;
            border-radius: 8px;
            font-size: 12px;
            font-weight: 500;
            cursor: pointer;
            font-family: 'DM Sans',sans-serif;
            margin-top: 12px;
            transition: background .15s;
            text-decoration: none;
            display: flex;
            align-items: center;
            justify-content: center;
        }

            .btn-book:hover {
                background: #1a6fa8;
                color: #fff;
                border-color: #1a6fa8;
            }

        /* ===== NEWS ===== */
        .news-grid {
            display: grid;
            grid-template-columns: repeat(3,1fr);
            gap: 20px;
        }

        .news-card {
            border: 1px solid #d4e8f5;
            border-radius: 14px;
            overflow: hidden;
            cursor: pointer;
            transition: transform .15s;
            background: #fff;
        }

            .news-card:hover {
                transform: translateY(-2px);
            }

        .news-img {
            height: 90px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 32px;
        }

        .news-body {
            padding: 14px 16px;
        }

        .news-cat {
            font-size: 10px;
            font-weight: 500;
            color: #1a6fa8;
            text-transform: uppercase;
            letter-spacing: .06em;
            margin-bottom: 6px;
        }

        .news-title {
            font-size: 13px;
            font-weight: 500;
            color: #0a4d7c;
            line-height: 1.45;
            margin-bottom: 6px;
        }

        .news-meta {
            font-size: 11px;
            color: #7a9bb0;
        }
    </style>
}
<!-- HERO -->
<section class="hero">
    <div class="hero-content">
        <div class="hero-tag">Chuyên khoa Tai Mũi Họng hàng đầu</div>
        <h1 class="hero-title">Chẩn đoán chính xác,<br>điều trị <em>Tai · Mũi · Họng</em><br>tận tâm</h1>
        <p class="hero-desc">Đội ngũ bác sĩ chuyên khoa TMH giàu kinh nghiệm, trang thiết bị nội soi hiện đại, điều trị toàn diện các bệnh lý về tai, mũi, họng và đầu cổ cho mọi lứa tuổi.</p>
        <div class="hero-btns">
            @if (ViewBag.IsLoggedIn == true)
            {
                <a asp-controller="Booking" asp-action="Index" class="btn-hero-primary">Đặt lịch khám ngay</a>
            }
            else
            {
                <a asp-controller="Account" asp-action="Register" class="btn-hero-primary">Đặt lịch khám ngay</a>
            }
            <a href="#bac-si" class="btn-hero-secondary">Tìm bác sĩ →</a>
        </div>
        <div class="hero-stats">
            <div class="stat-item"><div class="stat-num">18+</div><div class="stat-lbl">Năm kinh nghiệm</div></div>
            <div class="stat-div"></div>
            <div class="stat-item"><div class="stat-num">45</div><div class="stat-lbl">Bác sĩ chuyên khoa TMH</div></div>
            <div class="stat-div"></div>
            <div class="stat-item"><div class="stat-num">80K+</div><div class="stat-lbl">Bệnh nhân tin tưởng</div></div>
        </div>
    </div>

    <!-- Quick booking card — yêu cầu đăng nhập nếu chưa có tài khoản -->
    <div>
        <div class="hero-card">
            <div class="card-head-title">Đặt lịch khám Tai Mũi Họng</div>
            <div class="card-head-sub">Chọn vấn đề và thời gian phù hợp với bạn</div>
            <div class="appt-form-row">
                <div>
                    <label class="appt-label">Họ và tên</label>
                    <input class="appt-input" type="text" placeholder="Nguyễn Văn An" />
                </div>
                <div>
                    <label class="appt-label">Số điện thoại</label>
                    <input class="appt-input" type="text" placeholder="0901 234 567" />
                </div>
            </div>
            <div class="appt-form-full">
                <label class="appt-label">Vấn đề cần khám</label>
                <select class="appt-select">
                    <option value="">-- Chọn vấn đề --</option>
                    <optgroup label="Bệnh lý về TAI">
                        <option>Ù tai, giảm thính lực</option>
                        <option>Viêm tai giữa, viêm tai ngoài</option>
                        <option>Chóng mặt, rối loạn thăng bằng</option>
                        <option>Dị vật trong tai</option>
                    </optgroup>
                    <optgroup label="Bệnh lý về MŨI">
                        <option>Viêm mũi dị ứng, hắt hơi sổ mũi</option>
                        <option>Viêm xoang cấp và mãn tính</option>
                        <option>Lệch vách ngăn mũi</option>
                        <option>Polyp mũi</option>
                    </optgroup>
                    <optgroup label="Bệnh lý về HỌNG">
                        <option>Viêm họng, viêm amidan</option>
                        <option>Viêm thanh quản, khàn tiếng</option>
                        <option>Nuốt đau, khó nuốt</option>
                        <option>Ngáy ngủ, ngưng thở khi ngủ</option>
                    </optgroup>
                </select>
            </div>
            <div class="appt-form-row">
                <div>
                    <label class="appt-label">Ngày khám</label>
                    <input class="appt-input" type="date" />
                </div>
                <div>
                    <label class="appt-label">Buổi khám</label>
                    <select class="appt-select">
                        <option>Sáng (7h–11h)</option>
                        <option>Chiều (13h–17h)</option>
                    </select>
                </div>
            </div>
            @if (ViewBag.IsLoggedIn == true)
            {
                <a asp-controller="Booking" asp-action="Index" class="btn-appt" style="display:flex;align-items:center;justify-content:center;text-decoration:none;">Xác nhận đặt lịch</a>
            }
            else
            {
                <a asp-controller="Account" asp-action="Login" class="btn-appt" style="display:flex;align-items:center;justify-content:center;text-decoration:none;">Đăng nhập để đặt lịch</a>
            }
            <div class="appt-note">Miễn phí đặt lịch · <span>Xác nhận trong 15 phút</span></div>
        </div>
    </div>
</section>

<!-- SYMPTOM CHECKER -->
<section class="symptom-section" id="trieu-chung">
    <div class="section-tag" style="background:#fdf3d7;color:#c9a227;">Triệu chứng thường gặp</div>
    <div class="section-title">Bạn đang gặp vấn đề gì?</div>
    <div class="section-sub">Chọn triệu chứng để được tư vấn và đặt lịch khám phù hợp</div>
    <div class="symptom-grid">
        <a asp-controller="Account" asp-action="@(ViewBag.IsLoggedIn == true ? null : "Login")" class="sym-card" style="text-decoration:none;">
            <div class="sym-emoji">👂</div>
            <div class="sym-name">Ù tai · Nghe kém</div>
            <div class="sym-desc">Tiếng ve, tiếng vo ve trong tai, nghe không rõ</div>
        </a>
        <div class="sym-card">
            <div class="sym-emoji">🤧</div>
            <div class="sym-name">Nghẹt mũi · Viêm xoang</div>
            <div class="sym-desc">Chảy nước mũi, đau đầu, đau vùng mặt</div>
        </div>
        <div class="sym-card">
            <div class="sym-emoji">🗣️</div>
            <div class="sym-name">Đau họng · Khàn tiếng</div>
            <div class="sym-desc">Nuốt đau, rát họng, giọng khàn kéo dài</div>
        </div>
        <div class="sym-card">
            <div class="sym-emoji">💫</div>
            <div class="sym-name">Chóng mặt · Mất thăng bằng</div>
            <div class="sym-desc">Cảm giác quay cuồng, buồn nôn, đi không vững</div>
        </div>
    </div>
</section>

<!-- SERVICES -->
<section class="section" id="dich-vu">
    <div class="section-tag">Dịch vụ chuyên khoa</div>
    <div class="section-title">Dịch vụ Tai · Mũi · Họng</div>
    <div class="section-sub">Trang bị hệ thống nội soi TMH thế hệ mới, chẩn đoán chính xác và điều trị hiệu quả</div>
    <div class="services-grid">
        <div class="svc-card">
            <div class="svc-icon"><svg width="22" height="22" viewBox="0 0 22 22" fill="none"><circle cx="11" cy="11" r="7" stroke="#1a6fa8" stroke-width="1.5" /><circle cx="11" cy="11" r="3" fill="#1a6fa8" opacity="0.3" /><path d="M16 16l3 3" stroke="#1a6fa8" stroke-width="1.8" stroke-linecap="round" /></svg></div>
            <div class="svc-name">Nội soi TMH</div>
            <div class="svc-desc">Nội soi tai, mũi, họng, thanh quản bằng ống soi mềm độ phân giải cao.</div>
            <span class="svc-badge">✦ Công nghệ HD</span>
        </div>
        <div class="svc-card">
            <div class="svc-icon"><svg width="22" height="22" viewBox="0 0 22 22" fill="none"><path d="M5 11c0-3.3 2.7-6 6-6s6 2.7 6 6-2.7 6-6 6" stroke="#1a6fa8" stroke-width="1.5" stroke-linecap="round" /><path d="M8 11c0-1.7 1.3-3 3-3" stroke="#1a6fa8" stroke-width="1.5" stroke-linecap="round" /><circle cx="11" cy="11" r="1.5" fill="#1a6fa8" /></svg></div>
            <div class="svc-name">Đo thính lực</div>
            <div class="svc-desc">Đánh giá toàn diện chức năng nghe — đo nhĩ lượng, đo thính lực đơn âm.</div>
            <span class="svc-badge">Trẻ em từ 3 tuổi</span>
        </div>
        <div class="svc-card">
            <div class="svc-icon"><svg width="22" height="22" viewBox="0 0 22 22" fill="none"><ellipse cx="11" cy="9" rx="5" ry="4" stroke="#1a6fa8" stroke-width="1.5" /><path d="M11 13v5" stroke="#1a6fa8" stroke-width="1.5" stroke-linecap="round" /><path d="M8 16h6" stroke="#1a6fa8" stroke-width="1.5" stroke-linecap="round" /></svg></div>
            <div class="svc-name">Điều trị viêm xoang</div>
            <div class="svc-desc">Điều trị nội khoa và phẫu thuật nội soi xoang chức năng (FESS) tiên tiến.</div>
        </div>
        <div class="svc-card">
