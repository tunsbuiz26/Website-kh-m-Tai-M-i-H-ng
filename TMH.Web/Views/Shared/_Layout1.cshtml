<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewBag.Title ?? "Phòng Khám Tai Mũi Họng")</title>
    <link href="https://fonts.googleapis.com/css2?family=Crimson+Pro:wght@400;600&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    @*
    _Layout.cshtml là "khung" dùng chung cho toàn bộ Web App.
    Mọi trang đều kế thừa layout này. Phần nội dung riêng của từng trang
    được chèn vào @RenderBody().

    Header thay đổi động theo trạng thái đăng nhập:
      - Chưa đăng nhập: hiển thị nút "Đăng nhập" và "Đăng ký"
      - Đã đăng nhập: hiển thị tên người dùng, role, và dropdown menu
*@

    @{
        // Đọc trạng thái đăng nhập từ Session (được set trong AccountController)
        bool isLoggedIn = Context.Session.GetString("JwtToken") != null;
        string userName = Context.Session.GetString("UserName") ?? "";
        string userRole = Context.Session.GetString("UserRole") ?? "";

        // Dịch role code → tên hiển thị tiếng Việt
        string roleDisplay = userRole switch
        {
            "Admin" => "Quản trị viên",
            "Doctor" => "Bác sĩ",
            "Staff" => "Lễ tân / Nhân viên",
            "Patient" => "Bệnh nhân",
            _ => ""
        };

        // Initials cho avatar (2 chữ đầu của tên)
        string initials = userName.Length >= 2 ? userName[..2].ToUpper() : "??";
    }

    <!-- ===== NAVBAR ===== -->
    <nav class="nav">
        <div class="nav-logo">
            <div class="logo-icon">
                <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
                    <path d="M10 3v14M3 10h14" stroke="#fff" stroke-width="2.5" stroke-linecap="round" />
                </svg>
            </div>
            <a asp-controller="Home" asp-action="Index" class="logo-name">
                Phòng Khám <span>Tai Mũi Họng</span>
            </a>
        </div>

        <div class="nav-links">
            <a asp-controller="Home" asp-action="Index"
               class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")">
                Trang chủ
            </a>
            <a href="#dich-vu" class="nav-link">Dịch vụ</a>
            <a href="#bac-si" class="nav-link">Bác sĩ</a>
            <a href="#tin-tuc" class="nav-link">Tin tức</a>
            <a asp-controller="Home" asp-action="Contact" class="nav-link">Liên hệ</a>
        </div>

        <div class="nav-actions">
            @if (!isLoggedIn)
            {
                @* Chưa đăng nhập: hiện nút Đăng nhập & Đăng ký *@
                <a asp-controller="Account" asp-action="Login" class="btn-outline">Đăng nhập</a>
                <a asp-controller="Account" asp-action="Register" class="btn-solid">Đăng ký</a>
            }
            else
            {
                @* Đã đăng nhập: hiện avatar + dropdown menu *@
                <div class="user-dropdown" id="userDropdown">
                    <div class="user-toggle" onclick="toggleDropdown()">
                        <div class="user-avatar-sm">@initials</div>
                        <div class="user-toggle-info">
                            <span class="user-toggle-name">@userName</span>
                            <span class="user-toggle-role">@roleDisplay</span>
                        </div>
                        <svg width="12" height="12" viewBox="0 0 12 12" fill="none" style="opacity:.5">
                            <path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
                        </svg>
                    </div>

                    <div class="dropdown-menu" id="dropdownMenu">
                        <!-- Menu items khác nhau tùy theo Role -->
                        @if (userRole == "Patient")
                        {
                            <a asp-controller="Patient" asp-action="Index" class="dd-item">📅 Lịch khám của tôi</a>
                            <a asp-controller="Patient" asp-action="Results" class="dd-item">🧪 Kết quả xét nghiệm</a>
                            <a asp-controller="Patient" asp-action="Profile" class="dd-item">👤 Hồ sơ cá nhân</a>
                        }
                        @if (userRole == "Doctor")
                        {
                            <a asp-controller="Doctor" asp-action="Dashboard" class="dd-item">🩺 Dashboard bác sĩ</a>
                            <a asp-controller="Doctor" asp-action="Schedule" class="dd-item">📅 Lịch khám hôm nay</a>
                            <a asp-controller="Doctor" asp-action="Patients" class="dd-item">👥 Danh sách bệnh nhân</a>
                        }
                        @if (userRole == "Staff")
                        {
                            <a asp-controller="Staff" asp-action="Dashboard" class="dd-item">🖥️ Dashboard nhân viên</a>
                            <a asp-controller="Staff" asp-action="Appointments" class="dd-item">📋 Quản lý lịch đặt khám</a>
                        }
                        @if (userRole == "Admin")
                        {
                            <a asp-controller="Admin" asp-action="Dashboard" class="dd-item">⚙️ Dashboard quản trị</a>
                            <a asp-controller="Admin" asp-action="Users" class="dd-item">👥 Quản lý người dùng</a>
                            <a asp-controller="Admin" asp-action="Reports" class="dd-item">📊 Báo cáo thống kê</a>
                        }
                        <div class="dd-divider"></div>
                        <a asp-controller="Account" asp-action="Logout" class="dd-item dd-logout">🚪 Đăng xuất</a>
                    </div>
                </div>
            }
        </div>
    </nav>

    <!-- ===== THÔNG BÁO TOÀN CỤC (TempData) ===== -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success" id="globalAlert">
            @TempData["SuccessMessage"]
            <button onclick="document.getElementById('globalAlert').remove()">✕</button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-error" id="globalAlertErr">
            @TempData["ErrorMessage"]
            <button onclick="document.getElementById('globalAlertErr').remove()">✕</button>
        </div>
    }

    <!-- ===== NỘI DUNG TRANG ===== -->
    <main>
        @RenderBody()
    </main>

    <!-- ===== FOOTER ===== -->
    <footer class="footer">
        <div class="footer-grid">
            <div>
                <div class="footer-brand">Phòng Khám <span>Tai Mũi Họng</span></div>
                <div class="footer-desc">Chuyên khoa Tai Mũi Họng hàng đầu với đội ngũ bác sĩ chuyên sâu và hệ thống nội soi thế hệ mới.</div>
                <div class="footer-contact">
                    <div><strong>Địa chỉ:</strong> 123 Đường Y Tế, Q.1, TP.HCM</div>
                    <div><strong>Hotline:</strong> 1800 5678</div>
                    <div><strong>Email:</strong> <a href="mailto:info@pktatmuihong.vn">info@pktatmuihong.vn</a></div>
                </div>
            </div>
            <div>
                <div class="footer-heading">Dịch vụ TMH</div>
                <a href="#" class="footer-link">Nội soi Tai Mũi Họng</a>
                <a href="#" class="footer-link">Đo thính lực</a>
                <a href="#" class="footer-link">Điều trị viêm xoang</a>
                <a href="#" class="footer-link">Phẫu thuật Amidan</a>
                <a href="#" class="footer-link">TMH Nhi khoa</a>
            </div>
            <div>
                <div class="footer-heading">Bệnh nhân</div>
                @if (!isLoggedIn)
                {
                    <a asp-controller="Account" asp-action="Register" class="footer-link">Đăng ký tài khoản</a>
                    <a asp-controller="Account" asp-action="Login" class="footer-link">Đặt lịch khám</a>
                }
                else
                {
                    <a asp-controller="Booking" asp-action="Index" class="footer-link">Đặt lịch khám</a>
                    <a asp-controller="Patient" asp-action="Results" class="footer-link">Tra cứu kết quả</a>
                    <a asp-controller="Patient" asp-action="Profile" class="footer-link">Hồ sơ bệnh án</a>
                }
            </div>
            <div>
                <div class="footer-heading">Hỗ trợ</div>
                <a href="#" class="footer-link">Câu hỏi thường gặp</a>
                <a asp-controller="Home" asp-action="HuongDan" class="footer-link">Hướng dẫn khám</a>
                <a href="#" class="footer-link">Chính sách bảo mật</a>
                <a asp-controller="Home" asp-action="Contact" class="footer-link">Liên hệ hỗ trợ</a>
            </div>
        </div>
        <div class="footer-bottom">
            <span>© 2026 Phòng Khám Tai Mũi Họng. Bảo lưu mọi quyền.</span>
            <span>Hệ thống ASP.NET Core MVC ✦</span>
        </div>
    </footer>

    <script>
        // Toggle dropdown menu người dùng
        function toggleDropdown() {
            document.getElementById('dropdownMenu').classList.toggle('open');
        }
        // Nhấn ngoài dropdown thì đóng lại
        document.addEventListener('click', function(e) {
            var dd = document.getElementById('userDropdown');
            if (dd && !dd.contains(e.target))
                document.getElementById('dropdownMenu')?.classList.remove('open');
        });
        // Tự ẩn thông báo sau 4 giây
        setTimeout(function() {
            document.getElementById('globalAlert')?.remove();
            document.getElementById('globalAlertErr')?.remove();
        }, 4000);
    </script>

    @await RenderSectionAsync("Scripts", required: false)

    <!-- ===== CHATBOT FLOATING WIDGET ===== -->
    <style>
        /* --- Nút bubble --- */
        @@keyframes chatPulse {
            0%, 100% { box-shadow: 0 0 0 0 rgba(14,116,144,0.45); }
            50%       { box-shadow: 0 0 0 10px rgba(14,116,144,0); }
        }
        @@keyframes tmhFadeUp {
            from { opacity: 0; transform: translateY(12px) scale(0.97); }
            to   { opacity: 1; transform: translateY(0) scale(1); }
        }
        @@keyframes tmhTyping {
            0%, 60%, 100% { transform: translateY(0); opacity: 0.5; }
            30%            { transform: translateY(-5px); opacity: 1; }
        }

        .tmh-bubble {
            position: fixed;
            bottom: 28px; right: 28px;
            z-index: 9999;
            width: 56px; height: 56px;
            border-radius: 50%;
            background: linear-gradient(135deg, #0e7490, #0891b2);
            color: #fff;
            border: none;
            font-size: 24px;
            cursor: pointer;
            display: flex; align-items: center; justify-content: center;
            box-shadow: 0 4px 18px rgba(14,116,144,0.4);
            animation: chatPulse 2.5s ease-in-out infinite;
            transition: transform .15s;
        }
        .tmh-bubble:hover { transform: scale(1.08); }

        /* Badge số tin chưa đọc */
        .tmh-badge {
            position: absolute;
            top: -2px; right: -2px;
            background: #ef4444;
            color: #fff;
            font-size: 10px;
            font-weight: 700;
            width: 18px; height: 18px;
            border-radius: 50%;
            display: none;
            align-items: center; justify-content: center;
            border: 2px solid #fff;
        }
        .tmh-badge.show { display: flex; }

        /* --- Cửa sổ chat --- */
        .tmh-window {
            position: fixed;
            bottom: 96px; right: 28px;
            z-index: 9998;
            width: 360px;
            max-height: 540px;
            background: #fff;
            border-radius: 20px;
            box-shadow: 0 12px 40px rgba(14,116,144,0.2), 0 2px 8px rgba(0,0,0,0.08);
            display: none;
            flex-direction: column;
            overflow: hidden;
            font-family: 'DM Sans', sans-serif;
        }
        .tmh-window.open {
            display: flex;
            animation: tmhFadeUp 0.22s ease-out;
        }

        /* Header */
        .tmh-head {
            background: linear-gradient(135deg, #0e7490 0%, #0891b2 100%);
            padding: 14px 18px;
            display: flex; align-items: center; gap: 10px;
            flex-shrink: 0;
        }
        .tmh-head-icon {
            width: 36px; height: 36px;
            background: rgba(255,255,255,0.18);
            border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            font-size: 17px;
            border: 1.5px solid rgba(255,255,255,0.3);
        }
        .tmh-head-info { flex: 1; }
        .tmh-head-info strong {
            display: block;
            color: #fff;
            font-size: 14px;
            font-weight: 600;
        }
        .tmh-head-status {
            color: rgba(255,255,255,0.8);
            font-size: 11px;
            display: flex; align-items: center; gap: 4px;
            margin-top: 1px;
        }
        .tmh-head-dot {
            width: 7px; height: 7px;
            background: #4ade80;
            border-radius: 50%;
            animation: chatPulse 2s infinite;
        }
        .tmh-close {
            background: none; border: none;
            color: rgba(255,255,255,0.7);
            font-size: 20px; cursor: pointer;
            line-height: 1; padding: 2px;
            transition: color .15s;
        }
        .tmh-close:hover { color: #fff; }

        /* Quick chips */
        .tmh-chips {
            padding: 10px 12px;
            display: flex; gap: 6px;
            overflow-x: auto; scrollbar-width: none;
            background: #f0f9ff;
            border-bottom: 1px solid #e0f2fe;
            flex-shrink: 0;
        }
        .tmh-chips::-webkit-scrollbar { display: none; }
        .tmh-chip {
            white-space: nowrap;
            background: #fff;
            border: 1px solid #bae6fd;
            border-radius: 16px;
            padding: 4px 10px;
            font-size: 11.5px;
            color: #0e7490;
            cursor: pointer;
            font-family: 'DM Sans', sans-serif;
            font-weight: 500;
            transition: all .15s;
        }
        .tmh-chip:hover { background: #0e7490; color: #fff; border-color: #0e7490; }

        /* Messages */
        .tmh-messages {
            flex: 1;
            overflow-y: auto;
            padding: 14px 12px;
            display: flex; flex-direction: column; gap: 10px;
            background: #f8fbff;
            scroll-behavior: smooth;
        }
        .tmh-messages::-webkit-scrollbar { width: 3px; }
        .tmh-messages::-webkit-scrollbar-thumb { background: #bae6fd; border-radius: 3px; }

        .tmh-msg {
            display: flex; gap: 7px;
            animation: tmhFadeUp 0.2s ease-out;
        }
        .tmh-msg.user { flex-direction: row-reverse; }

        .tmh-msg-av {
            width: 28px; height: 28px;
            border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            font-size: 13px; flex-shrink: 0;
            align-self: flex-end;
        }
        .tmh-msg.bot .tmh-msg-av  { background: #e0f2fe; }
        .tmh-msg.user .tmh-msg-av { background: #0e7490; }

        .tmh-bub {
            max-width: 80%;
            padding: 9px 13px;
            border-radius: 16px;
            font-size: 13px;
            line-height: 1.55;
            white-space: pre-wrap;
            word-break: break-word;
        }
        .tmh-msg.bot  .tmh-bub { background: #fff; color: #0d2d44; border: 1px solid #dbeafe; border-bottom-left-radius: 4px; }
        .tmh-msg.user .tmh-bub { background: #0e7490; color: #fff; border-bottom-right-radius: 4px; }

        /* Disclaimer */
        .tmh-disclaimer {
            background: #fffbeb;
            border: 1px solid #fde68a;
            border-radius: 10px;
            padding: 8px 11px;
            font-size: 11.5px;
            color: #92400e;
            line-height: 1.5;
        }

        /* Typing dots */
        .tmh-typing { display: flex; gap: 4px; align-items: center; padding: 3px 2px; }
        .tmh-typing span {
            width: 6px; height: 6px;
            background: #0e7490;
            border-radius: 50%;
            animation: tmhTyping 1.2s infinite;
            opacity: 0.5;
        }
        .tmh-typing span:nth-child(2) { animation-delay: 0.2s; }
        .tmh-typing span:nth-child(3) { animation-delay: 0.4s; }

        /* Input */
        .tmh-footer {
            padding: 10px 12px;
            border-top: 1px solid #e0f2fe;
            display: flex; gap: 8px; align-items: center;
            background: #fff; flex-shrink: 0;
        }
        .tmh-input {
            flex: 1;
            border: 1.5px solid #bae6fd;
            border-radius: 14px;
            padding: 8px 13px;
            font-size: 13px;
            outline: none;
            font-family: 'DM Sans', sans-serif;
            color: #0d2d44;
            background: #f8fbff;
            transition: border-color .18s;
        }
        .tmh-input:focus { border-color: #0e7490; background: #fff; }
        .tmh-input::placeholder { color: #94a3b8; }
        .tmh-send {
            width: 36px; height: 36px;
            border-radius: 10px;
            background: #0e7490;
            color: #fff; border: none; cursor: pointer;
            display: flex; align-items: center; justify-content: center;
            transition: all .15s; flex-shrink: 0;
        }
        .tmh-send:hover { background: #0891b2; transform: scale(1.05); }
        .tmh-send svg { width: 16px; height: 16px; fill: #fff; }

        /* Footer note */
        .tmh-note {
            text-align: center;
            font-size: 10.5px;
            color: #94a3b8;
            padding: 5px 12px 10px;
            background: #fff;
            flex-shrink: 0;
        }
    </style>

    <!-- Nút bubble -->
    <button class="tmh-bubble" id="tmhBubble" onclick="tmhToggle()" title="Hỏi trợ lý AI">
        💬
        <span class="tmh-badge" id="tmhBadge">1</span>
    </button>

    <!-- Cửa sổ chat -->
    <div class="tmh-window" id="tmhWindow">
        <!-- Header -->
        <div class="tmh-head">
            <div class="tmh-head-icon">🏥</div>
            <div class="tmh-head-info">
                <strong>Trợ Lý TMH AI</strong>
                <div class="tmh-head-status">
                    <div class="tmh-head-dot"></div>
                    <span>Sẵn sàng hỗ trợ</span>
                </div>
            </div>
            <button class="tmh-close" onclick="tmhToggle()" title="Đóng">✕</button>
        </div>

        <!-- Quick chips -->
        <div class="tmh-chips">
            <button class="tmh-chip" onclick="tmhQuick('Giờ làm việc của phòng khám?')">🕐 Giờ mở cửa</button>
            <button class="tmh-chip" onclick="tmhQuick('Phí khám bao nhiêu?')">💰 Phí khám</button>
            <button class="tmh-chip" onclick="tmhQuick('Hướng dẫn đặt lịch khám')">📅 Đặt lịch</button>
            <button class="tmh-chip" onclick="tmhQuick('Tôi bị ù tai phải làm sao?')">👂 Ù tai</button>
            <button class="tmh-chip" onclick="tmhQuick('Tôi bị viêm xoang nghẹt mũi')">🤧 Viêm xoang</button>
            <button class="tmh-chip" onclick="tmhQuick('Danh sách bác sĩ phòng khám')">👨‍⚕️ Bác sĩ</button>
        </div>

        <!-- Messages -->
        <div class="tmh-messages" id="tmhMessages">
            <!-- Tin chào + disclaimer -->
            <div class="tmh-msg bot">
                <div class="tmh-msg-av">🤖</div>
                <div>
                    <div class="tmh-disclaimer">
                        ⚠️ Trợ lý AI chỉ hỗ trợ tư vấn sơ bộ, không thay thế chẩn đoán y khoa.
                    </div>
                </div>
            </div>
            <div class="tmh-msg bot">
                <div class="tmh-msg-av">🤖</div>
                <div class="tmh-bub">Xin chào! 👋 Tôi có thể giúp bạn về triệu chứng tai mũi họng, hướng dẫn đặt lịch khám, hoặc thông tin phòng khám. Bạn cần hỗ trợ gì?</div>
            </div>
        </div>

        <!-- Input -->
        <div class="tmh-footer">
            <input class="tmh-input" id="tmhInput" type="text"
                   placeholder="Nhập câu hỏi..." maxlength="500"
                   onkeydown="if(event.key==='Enter')tmhSend()" />
            <button class="tmh-send" onclick="tmhSend()" title="Gửi">
                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z" />
                </svg>
            </button>
        </div>
        <div class="tmh-note">Powered by Claude AI &nbsp;·&nbsp; Phòng Khám Tai Mũi Họng</div>
    </div>

    <script>
        var tmhHistory  = [];
        var tmhIsOpen   = false;
        var tmhIsBusy   = false;

        // Hiện badge "1" khi trang load để thu hút chú ý
        setTimeout(function () {
            var badge = document.getElementById('tmhBadge');
            if (badge && !tmhIsOpen) badge.classList.add('show');
        }, 2000);

        function tmhToggle() {
            tmhIsOpen = !tmhIsOpen;
            document.getElementById('tmhWindow').classList.toggle('open', tmhIsOpen);
            if (tmhIsOpen) {
                // Ẩn badge khi mở
                document.getElementById('tmhBadge').classList.remove('show');
                document.getElementById('tmhInput').focus();
            }
        }

        function tmhQuick(text) {
            document.getElementById('tmhInput').value = text;
            tmhSend();
        }

        function tmhScrollBottom() {
            var box = document.getElementById('tmhMessages');
            box.scrollTop = box.scrollHeight;
        }

        function tmhAppend(role, html) {
            var box  = document.getElementById('tmhMessages');
            var wrap = document.createElement('div');
            wrap.className = 'tmh-msg ' + role;

            var av = document.createElement('div');
            av.className = 'tmh-msg-av';
            av.textContent = role === 'bot' ? '🤖' : '🧑';

            var bub = document.createElement('div');
            bub.className = 'tmh-bub';
            bub.innerHTML = html;

            wrap.appendChild(av);
            wrap.appendChild(bub);
            box.appendChild(wrap);
            tmhScrollBottom();
            return bub;
        }

        function tmhShowTyping() {
            var box  = document.getElementById('tmhMessages');
            var wrap = document.createElement('div');
            wrap.className = 'tmh-msg bot';
            wrap.id = 'tmhTyping';

            var av = document.createElement('div');
            av.className = 'tmh-msg-av';
            av.textContent = '🤖';

            var bub = document.createElement('div');
            bub.className = 'tmh-bub';
            bub.innerHTML = '<div class="tmh-typing"><span></span><span></span><span></span></div>';

            wrap.appendChild(av);
            wrap.appendChild(bub);
            box.appendChild(wrap);
            tmhScrollBottom();
        }

        function tmhRemoveTyping() {
            var el = document.getElementById('tmhTyping');
            if (el) el.remove();
        }

        function tmhFormatText(text) {
            return text
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
                .replace(/\n/g, '<br>');
        }

        function tmhSend() {
            if (tmhIsBusy) return;
            var input = document.getElementById('tmhInput');
            var msg   = input.value.trim();
            if (!msg) return;

            input.value = '';
            tmhAppend('user', tmhFormatText(msg));
            tmhHistory.push({ role: 'user', content: msg });

            tmhIsBusy = true;
            tmhShowTyping();

            // Gọi qua ChatProxyController của TMH.Web (giữ nguyên luồng backend)
            fetch('/api/chat-proxy', {
                method:  'POST',
                headers: { 'Content-Type': 'application/json' },
                body:    JSON.stringify({
                    message: msg,
                    history: tmhHistory.slice(-10)   // tối đa 10 tin gần nhất, giống TakeLast(10) trong C#
                })
            })
            .then(function(r) { return r.json(); })
            .then(function(data) {
                tmhRemoveTyping();
                var reply = data.reply || 'Xin lỗi, có lỗi xảy ra. Vui lòng thử lại.';
                tmhHistory.push({ role: 'assistant', content: reply });
                tmhAppend('bot', tmhFormatText(reply));
            })
            .catch(function() {
                tmhRemoveTyping();
                tmhAppend('bot', 'Không kết nối được đến máy chủ. Vui lòng thử lại hoặc gọi hotline <strong>1900 xxxx</strong>.');
            })
            .finally(function() {
                tmhIsBusy = false;
            });
        }
    </script>

