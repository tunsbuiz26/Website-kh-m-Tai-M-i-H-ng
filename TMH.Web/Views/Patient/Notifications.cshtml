@{
    ViewBag.Title = "Thông báo";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var notifsJson = ViewBag.NotificationsJson as string ?? "[]";
}
<style>
    .notif-wrap { max-width: 720px; margin: 36px auto; padding: 0 20px; }
    .notif-title { font-family:'Crimson Pro',serif; font-size:26px; font-weight:600; color:#0a4d7c; margin-bottom:4px; }
    .notif-sub   { font-size:13px; color:#7a9bb0; margin-bottom:24px; }

    .notif-card { background:#fff; border:1px solid #d4e8f5; border-radius:12px; padding:16px 18px; margin-bottom:10px; display:flex; gap:14px; align-items:flex-start; cursor:pointer; transition:all .15s; }
    .notif-card.unread { border-left:4px solid #0a4d7c; background:#f8fbff; }
    .notif-card:hover { box-shadow:0 4px 14px rgba(10,77,124,.08); }
    .notif-icon { width:40px; height:40px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:18px; flex-shrink:0; }
    .icon-xac   { background:#cce5ff; }
    .icon-nhac  { background:#fff3cd; }
    .icon-huy   { background:#fdecea; }
    .icon-doi   { background:#d4edda; }
    .notif-body { flex:1; }
    .notif-ttl  { font-size:14px; font-weight:500; color:#0a4d7c; margin-bottom:3px; }
    .notif-card.unread .notif-ttl { font-weight:600; }
    .notif-content { font-size:13px; color:#555; line-height:1.5; }
    .notif-time { font-size:11px; color:#9ab0bf; margin-top:5px; }
    .unread-dot { width:8px; height:8px; background:#0a4d7c; border-radius:50%; flex-shrink:0; margin-top:4px; }

    .empty-state { text-align:center; padding:48px; background:#fff; border:1px solid #d4e8f5; border-radius:14px; color:#7a9bb0; }
    .mark-all-btn { font-size:12px; color:#1a6fa8; background:none; border:none; cursor:pointer; font-family:'DM Sans',sans-serif; text-decoration:underline; }
</style>

<div class="notif-wrap">
    <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:4px;">
        <div class="notif-title">Thông báo</div>
        <button class="mark-all-btn" onclick="markAllRead()">Đánh dấu tất cả đã đọc</button>
    </div>
    <div class="notif-sub">Thông báo xác nhận lịch khám và nhắc lịch của bạn</div>
    <div id="notifList"></div>
</div>

@Html.AntiForgeryToken()
<script type="application/json" id="_notifsData">@Html.Raw(notifsJson)</script>

@section Scripts {
<script>
    var csrfToken = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
    var typeIcons = { 'XacNhanLich':'✅','NhacLich':'🔔','HuyLich':'❌','DoiLich':'🔄' };
    var typeClass = { 'XacNhanLich':'icon-xac','NhacLich':'icon-nhac','HuyLich':'icon-huy','DoiLich':'icon-doi' };

    var notifs = [];
    try {
        notifs = JSON.parse(document.getElementById('_notifsData').textContent || '[]');
        if (!Array.isArray(notifs)) notifs = [];

        var el = document.getElementById('notifList');
        if (!notifs.length) {
            el.innerHTML = '<div class="empty-state"><div style="font-size:40px;margin-bottom:12px;">🔔</div>' +
                '<div style="font-size:15px;font-weight:500;color:#0a4d7c;margin-bottom:6px;">Chưa có thông báo</div>' +
                '<div style="font-size:13px;">Thông báo xác nhận và nhắc lịch sẽ xuất hiện ở đây.</div></div>';
        } else {
            el.innerHTML = notifs.map(function(n) {
                var ico   = typeIcons[n.type] || '📋';
                var cls   = typeClass[n.type]  || 'icon-xac';
                var time  = n.sentAt || '';
                return '<div class="notif-card ' + (n.isRead?'':'unread') + '" id="notif-' + n.id + '" onclick="markRead(' + n.id + ')">' +
                    '<div class="notif-icon ' + cls + '">' + ico + '</div>' +
                    '<div class="notif-body">' +
                        '<div class="notif-ttl">' + n.title + '</div>' +
                        '<div class="notif-content">' + n.content + '</div>' +
                        '<div class="notif-time">' + time + '</div>' +
                    '</div>' +
                    (!n.isRead ? '<div class="unread-dot"></div>' : '') +
                    '</div>';
            }).join('');
        }
    } catch(e) { console.error(e); }

    function markRead(id) {
        var card = document.getElementById('notif-' + id);
        if (!card || !card.classList.contains('unread')) return;
        fetch('/Patient/MarkRead?id=' + id, { method:'POST', headers:{'RequestVerificationToken':csrfToken} })
        .then(function(r){ return r.json(); })
        .then(function(d){
            if (d.success) {
                card.classList.remove('unread');
                var dot = card.querySelector('.unread-dot');
                if (dot) dot.remove();
            }
        });
    }

    function markAllRead() {
        document.querySelectorAll('.notif-card.unread').forEach(function(c) {
            var id = c.id.replace('notif-','');
            markRead(parseInt(id));
        });
    }
</script>
}
