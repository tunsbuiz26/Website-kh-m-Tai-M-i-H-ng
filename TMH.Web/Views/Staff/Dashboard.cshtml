@{
    ViewBag.Title = "Quản lý lịch khám — Lễ tân";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var doctors = ViewBag.Doctors as List<TMH.Shared.DTOs.DoctorScheduleDto>
                  ?? new List<TMH.Shared.DTOs.DoctorScheduleDto>();
}
<style>
    .staff-wrap { max-width: 1100px; margin: 32px auto; padding: 0 20px; }
    .page-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px; flex-wrap: wrap; gap: 12px; }
    .page-title { font-family: 'Crimson Pro', serif; font-size: 26px; font-weight: 600; color: #0a4d7c; }
    .page-sub { font-size: 13px; color: #7a9bb0; margin-top: 2px; }

    /* Toolbar */
    .toolbar { display: flex; gap: 10px; align-items: center; flex-wrap: wrap; background: #fff; border: 1px solid #d4e8f5; border-radius: 12px; padding: 14px 18px; margin-bottom: 20px; }
    .toolbar label { font-size: 12px; font-weight: 500; color: #3a5a72; text-transform: uppercase; letter-spacing: .04em; }
    .toolbar input[type=date], .toolbar select {
        height: 36px; border: 1px solid #d4e8f5; border-radius: 8px;
        padding: 0 10px; font-size: 13px; color: #0d2d44; outline: none;
        font-family: 'DM Sans', sans-serif; background: #fff;
    }
    .toolbar input[type=date]:focus, .toolbar select:focus { border-color: #1a6fa8; }
    .btn-load { height: 36px; padding: 0 18px; background: #0a4d7c; color: #fff; border: none; border-radius: 8px; font-size: 13px; font-weight: 500; cursor: pointer; font-family: 'DM Sans', sans-serif; }
    .btn-load:hover { background: #1a6fa8; }
    .btn-walkin { height: 36px; padding: 0 16px; background: #fff; border: 1.5px solid #0a4d7c; color: #0a4d7c; border-radius: 8px; font-size: 13px; font-weight: 500; cursor: pointer; font-family: 'DM Sans', sans-serif; margin-left: auto; }
    .btn-walkin:hover { background: #0a4d7c; color: #fff; }

    /* Stats bar */
    .stats-bar { display: flex; gap: 12px; margin-bottom: 20px; flex-wrap: wrap; }
    .stat-card { flex: 1; min-width: 120px; background: #fff; border: 1px solid #d4e8f5; border-radius: 10px; padding: 12px 16px; text-align: center; }
    .stat-num { font-size: 24px; font-weight: 700; color: #0a4d7c; }
    .stat-lbl { font-size: 11px; color: #7a9bb0; margin-top: 2px; }
    .stat-card.cho   .stat-num { color: #856404; }
    .stat-card.den   .stat-num { color: #004085; }
    .stat-card.kham  .stat-num { color: #155724; }
    .stat-card.hoan  .stat-num { color: #383d41; }
    .stat-card.huy   .stat-num { color: #721c24; }

    /* Table */
    .apt-table-wrap { background: #fff; border: 1px solid #d4e8f5; border-radius: 14px; overflow: hidden; }
    .apt-table { width: 100%; border-collapse: collapse; font-size: 13px; }
    .apt-table thead { background: #f0f8ff; }
    .apt-table th { padding: 10px 14px; text-align: left; font-size: 11px; font-weight: 500; color: #3a5a72; text-transform: uppercase; letter-spacing: .04em; border-bottom: 1px solid #d4e8f5; }
    .apt-table td { padding: 12px 14px; border-bottom: 1px solid #f0f4f8; vertical-align: middle; color: #0d2d44; }
    .apt-table tr:last-child td { border-bottom: none; }
    .apt-table tr:hover td { background: #f8fbff; }

    .booking-code { font-family: monospace; font-size: 11px; background: #f0f8ff; padding: 2px 8px; border-radius: 4px; color: #1a6fa8; }
    .badge { display: inline-block; font-size: 11px; font-weight: 500; padding: 3px 10px; border-radius: 20px; white-space: nowrap; }
    .badge-cho     { background: #fff3cd; color: #856404; }
    .badge-xacnhan { background: #d1ecf1; color: #0c5460; }
    .badge-den     { background: #cce5ff; color: #004085; }
    .badge-kham    { background: #d4edda; color: #155724; }
    .badge-hoan    { background: #e2e3e5; color: #383d41; }
    .badge-huy     { background: #f8d7da; color: #721c24; }
    .badge-vang    { background: #fdecea; color: #a32d2d; }

    /* Action buttons */
    .action-group { display: flex; gap: 6px; flex-wrap: wrap; }
    .btn-action { height: 28px; padding: 0 10px; border-radius: 6px; font-size: 11px; font-weight: 500; cursor: pointer; border: 1px solid; font-family: 'DM Sans', sans-serif; white-space: nowrap; }
    .btn-checkin  { background: #e8f4fd; color: #0a4d7c; border-color: #b8d8f0; }
    .btn-checkin:hover { background: #0a4d7c; color: #fff; }
    .btn-kham     { background: #d4edda; color: #155724; border-color: #b8ddc4; }
    .btn-kham:hover { background: #155724; color: #fff; }
    .btn-hoan     { background: #e2e3e5; color: #383d41; border-color: #ccc; }
    .btn-hoan:hover { background: #383d41; color: #fff; }
    .btn-vang     { background: #fdecea; color: #a32d2d; border-color: #f5c6c6; }
    .btn-vang:hover { background: #a32d2d; color: #fff; }

    .empty-state { text-align: center; padding: 48px 20px; color: #7a9bb0; font-size: 13px; }

    /* Modal walk-in */
    .modal-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,.45); z-index: 9998; align-items: center; justify-content: center; }
    .modal-overlay.open { display: flex; }
    .modal-box { background: #fff; border-radius: 16px; padding: 28px; width: 460px; max-width: 95vw; max-height: 90vh; overflow-y: auto; }
    .modal-title { font-size: 16px; font-weight: 600; color: #0a4d7c; margin-bottom: 20px; }
    .form-label { font-size: 11px; font-weight: 500; color: #3a5a72; text-transform: uppercase; letter-spacing: .04em; margin-bottom: 4px; display: block; }
    .form-control { width: 100%; height: 38px; border: 1px solid #d4e8f5; border-radius: 8px; padding: 0 12px; font-size: 13px; color: #0d2d44; outline: none; font-family: 'DM Sans', sans-serif; margin-bottom: 14px; box-sizing: border-box; }
    .form-control:focus { border-color: #1a6fa8; }
    .modal-footer { display: flex; gap: 10px; margin-top: 20px; }
    .btn-modal-cancel { flex: 1; height: 40px; background: #f5f5f5; color: #555; border: none; border-radius: 9px; font-size: 13px; cursor: pointer; font-family: 'DM Sans', sans-serif; }
    .btn-modal-save   { flex: 2; height: 40px; background: #0a4d7c; color: #fff; border: none; border-radius: 9px; font-size: 13px; font-weight: 500; cursor: pointer; font-family: 'DM Sans', sans-serif; }
    .btn-modal-save:hover { background: #1a6fa8; }
    .msg-err { background: #fdecea; border: 1px solid #f5c6c6; border-radius: 8px; padding: 10px 14px; margin-bottom: 12px; color: #c0392b; font-size: 12px; display: none; }
    .msg-ok  { background: #e8f5e9; border: 1px solid #a5d6a7; border-radius: 8px; padding: 10px 14px; margin-bottom: 12px; color: #2d7a52; font-size: 12px; display: none; }

    .loading-row td { text-align: center; padding: 32px; color: #7a9bb0; }
</style>

<div class="staff-wrap">
    <div class="page-header">
        <div>
            <div class="page-title">Quản lý lịch khám</div>
            <div class="page-sub">Xin chào, @ViewBag.UserName — Lễ tân phòng khám Tai Mũi Họng</div>
        </div>
    </div>

    <!-- Toolbar -->
    <div class="toolbar">
        <label>Ngày khám</label>
        <input type="date" id="filterDate" />

        <label>Bác sĩ</label>
        <select id="filterDoctor">
            <option value="">Tất cả bác sĩ</option>
            @foreach (var doc in doctors)
            {
                <option value="@doc.DoctorId">@doc.FullName</option>
            }
        </select>

        <button class="btn-load" onclick="loadAppointments()">Xem lịch</button>
        <button class="btn-walkin" onclick="openWalkIn()">+ Walk-in</button>
    </div>

    <!-- Stats -->
    <div class="stats-bar">
        <div class="stat-card cho">
            <div class="stat-num" id="statCho">0</div>
            <div class="stat-lbl">Chờ xác nhận</div>
        </div>
        <div class="stat-card den">
            <div class="stat-num" id="statDen">0</div>
            <div class="stat-lbl">Đã đến</div>
        </div>
        <div class="stat-card kham">
            <div class="stat-num" id="statKham">0</div>
            <div class="stat-lbl">Đang khám</div>
        </div>
        <div class="stat-card hoan">
            <div class="stat-num" id="statHoan">0</div>
            <div class="stat-lbl">Hoàn thành</div>
        </div>
        <div class="stat-card huy">
            <div class="stat-num" id="statHuy">0</div>
            <div class="stat-lbl">Đã huỷ / Vắng</div>
        </div>
    </div>

    <!-- Table -->
    <div class="apt-table-wrap">
        <table class="apt-table">
            <thead>
                <tr>
                    <th>Mã lịch</th>
                    <th>Bệnh nhân</th>
                    <th>Bác sĩ</th>
                    <th>Giờ khám</th>
                    <th>Trạng thái</th>
                    <th>Thao tác</th>
                </tr>
            </thead>
            <tbody id="aptBody">
                <tr class="loading-row"><td colspan="6">Chọn ngày và bấm "Xem lịch" để tải danh sách</td></tr>
            </tbody>
        </table>
    </div>
</div>

<!-- Modal Walk-in -->
<div class="modal-overlay" id="walkInModal" onclick="if(event.target===this)closeWalkIn()">
    <div class="modal-box">
        <div class="modal-title">Tạo lịch Walk-in</div>
        <div class="msg-err" id="wiErr"></div>
        <div class="msg-ok"  id="wiOk"></div>

        <label class="form-label">Bác sĩ *</label>
        <select class="form-control" id="wiDoctor">
            <option value="">-- Chọn bác sĩ --</option>
            @foreach (var doc in doctors)
            {
                <option value="@doc.DoctorId">@doc.FullName — @doc.Specialty</option>
            }
        </select>

        <label class="form-label">Khung giờ *</label>
        <select class="form-control" id="wiSlot">
            <option value="">-- Chọn bác sĩ trước --</option>
        </select>

        <label class="form-label">Mã hồ sơ bệnh nhân (PatientId) *</label>
        <input type="number" class="form-control" id="wiPatientId" placeholder="Nhập ID hồ sơ bệnh nhân" min="1" />

        <label class="form-label">Ghi chú</label>
        <input type="text" class="form-control" id="wiNote" placeholder="Lý do đến khám..." />

        <div class="modal-footer">
            <button class="btn-modal-cancel" onclick="closeWalkIn()">Huỷ</button>
            <button class="btn-modal-save" id="wiSaveBtn" onclick="saveWalkIn()">Tạo lịch</button>
        </div>
    </div>
</div>

@section Scripts {
<script>
    var csrfToken = '@Html.AntiForgeryToken()'.match(/value="([^"]+)"/)?.[1] || '';
    var doctorData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(doctors));
    var appointments = [];

    // Set default date = hôm nay
    document.getElementById('filterDate').value = new Date().toISOString().split('T')[0];

    // Load tự động khi trang load
    window.addEventListener('DOMContentLoaded', loadAppointments);

    function loadAppointments() {
        var date = document.getElementById('filterDate').value;
        if (!date) { alert('Vui lòng chọn ngày'); return; }
        var doctorId = document.getElementById('filterDoctor').value;
        var url = '/Staff/GetAppointments?date=' + date + (doctorId ? '&doctorId=' + doctorId : '');

        var tbody = document.getElementById('aptBody');
        tbody.innerHTML = '<tr class="loading-row"><td colspan="6">Đang tải...</td></tr>';

        fetch(url)
            .then(function(r) { return r.json(); })
            .then(function(data) {
                appointments = data;
                renderTable(data);
                updateStats(data);
            })
            .catch(function() {
                tbody.innerHTML = '<tr class="loading-row"><td colspan="6">Lỗi kết nối. Vui lòng thử lại.</td></tr>';
            });
    }

    function renderTable(data) {
        var tbody = document.getElementById('aptBody');
        if (!data.length) {
            tbody.innerHTML = '<tr><td colspan="6" class="empty-state">Không có lịch khám nào trong ngày này</td></tr>';
            return;
        }

        tbody.innerHTML = data.map(function(a) {
            var badgeClass = {
                'ChoXacNhan': 'badge-cho', 'DaXacNhan': 'badge-xacnhan',
                'DaDen': 'badge-den', 'DangKham': 'badge-kham',
                'HoanThanh': 'badge-hoan', 'DaHuy': 'badge-huy', 'VangMat': 'badge-vang'
            }[a.status] || 'badge-cho';

            var actions = buildActions(a);

            return '<tr>' +
                '<td><span class="booking-code">' + a.bookingCode + '</span></td>' +
                '<td><strong>' + a.patientName + '</strong></td>' +
                '<td>' + a.doctorName + '<br><small style="color:#c9a227">' + a.specialty + '</small></td>' +
                '<td>' + a.startTime + ' – ' + a.endTime + '</td>' +
                '<td><span class="badge ' + badgeClass + '">' + a.statusDisplay + '</span></td>' +
                '<td><div class="action-group">' + actions + '</div></td>' +
                '</tr>';
        }).join('');
    }

    function buildActions(a) {
        var btns = '';
        if (a.status === 'ChoXacNhan' || a.status === 'DaXacNhan') {
            btns += '<button class="btn-action btn-checkin" onclick="updateStatus(' + a.id + ',\'DaDen\')">Check-in</button>';
        }
        if (a.status === 'DaDen') {
            btns += '<button class="btn-action btn-kham" onclick="updateStatus(' + a.id + ',\'DangKham\')">Bắt đầu khám</button>';
            btns += '<button class="btn-action btn-vang" onclick="updateStatus(' + a.id + ',\'VangMat\')">Vắng mặt</button>';
        }
        if (a.status === 'DangKham') {
            btns += '<button class="btn-action btn-hoan" onclick="updateStatus(' + a.id + ',\'HoanThanh\')">Hoàn thành</button>';
        }
        if (!btns) btns = '<span style="font-size:11px;color:#bbb;">—</span>';
        return btns;
    }

    function updateStatus(appointmentId, newStatus) {
        var label = { 'DaDen': 'check-in', 'DangKham': 'bắt đầu khám', 'HoanThanh': 'hoàn thành', 'VangMat': 'đánh vắng mặt' }[newStatus] || newStatus;
        if (!confirm('Xác nhận ' + label + ' cho lịch này?')) return;

        fetch('/Staff/UpdateStatus', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': csrfToken },
            body: JSON.stringify({ appointmentId: appointmentId, newStatus: newStatus })
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            if (data.success) {
                loadAppointments();
            } else {
                alert(data.message || 'Có lỗi xảy ra');
            }
        })
        .catch(function() { alert('Lỗi kết nối'); });
    }

    function updateStats(data) {
        document.getElementById('statCho').textContent  = data.filter(function(a) { return a.status === 'ChoXacNhan' || a.status === 'DaXacNhan'; }).length;
        document.getElementById('statDen').textContent  = data.filter(function(a) { return a.status === 'DaDen'; }).length;
        document.getElementById('statKham').textContent = data.filter(function(a) { return a.status === 'DangKham'; }).length;
        document.getElementById('statHoan').textContent = data.filter(function(a) { return a.status === 'HoanThanh'; }).length;
        document.getElementById('statHuy').textContent  = data.filter(function(a) { return a.status === 'DaHuy' || a.status === 'VangMat'; }).length;
    }

    // ── Walk-in modal ─────────────────────────────────────────────
    function openWalkIn() {
        document.getElementById('wiErr').style.display = 'none';
        document.getElementById('wiOk').style.display  = 'none';
        document.getElementById('wiDoctor').value   = '';
        document.getElementById('wiSlot').innerHTML = '<option value="">-- Chọn bác sĩ trước --</option>';
        document.getElementById('wiPatientId').value = '';
        document.getElementById('wiNote').value = '';
        document.getElementById('walkInModal').classList.add('open');
    }

    function closeWalkIn() { document.getElementById('walkInModal').classList.remove('open'); }

    document.getElementById('wiDoctor').addEventListener('change', function() {
        var docId = parseInt(this.value);
        var slotSel = document.getElementById('wiSlot');
        slotSel.innerHTML = '<option value="">-- Chọn khung giờ --</option>';
        if (!docId) return;

        var doc = doctorData.find(function(d) { return d.DoctorId === docId; });
        if (!doc || !doc.AvailableSlots.length) {
            slotSel.innerHTML = '<option value="">Không có khung giờ trống</option>';
            return;
        }
        doc.AvailableSlots.forEach(function(s) {
            var d = new Date(s.WorkDate);
            var label = d.toLocaleDateString('vi-VN') + ' — ' + s.StartTime + ' – ' + s.EndTime + ' (còn ' + s.RemainingSlots + ')';
            var opt = new Option(label, s.ScheduleId);
            slotSel.appendChild(opt);
        });
    });

    function saveWalkIn() {
        var doctorId  = parseInt(document.getElementById('wiDoctor').value);
        var scheduleId = parseInt(document.getElementById('wiSlot').value);
        var patientId  = parseInt(document.getElementById('wiPatientId').value);
        var note = document.getElementById('wiNote').value.trim();
        var errEl = document.getElementById('wiErr');
        var okEl  = document.getElementById('wiOk');

        errEl.style.display = 'none'; okEl.style.display = 'none';

        if (!doctorId)   { errEl.textContent = 'Vui lòng chọn bác sĩ.';      errEl.style.display = 'block'; return; }
        if (!scheduleId) { errEl.textContent = 'Vui lòng chọn khung giờ.';   errEl.style.display = 'block'; return; }
        if (!patientId)  { errEl.textContent = 'Vui lòng nhập ID hồ sơ bệnh nhân.'; errEl.style.display = 'block'; return; }

        var btn = document.getElementById('wiSaveBtn');
        btn.disabled = true; btn.textContent = 'Đang tạo...';

        fetch('/Staff/CreateWalkIn', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': csrfToken },
            body: JSON.stringify({ patientId: patientId, doctorId: doctorId, scheduleId: scheduleId, note: note || null })
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            if (data.success) {
                okEl.textContent = data.message;
                okEl.style.display = 'block';
                setTimeout(function() {
                    closeWalkIn();
                    loadAppointments();
                }, 1500);
            } else {
                errEl.textContent = data.message || 'Có lỗi xảy ra.';
                errEl.style.display = 'block';
            }
        })
        .catch(function() { errEl.textContent = 'Lỗi kết nối.'; errEl.style.display = 'block'; })
        .finally(function() { btn.disabled = false; btn.textContent = 'Tạo lịch'; });
    }
</script>
}
