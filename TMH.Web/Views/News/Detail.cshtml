@{
    ViewBag.Title = "Chi tiết bài viết";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<style>
    .detail-wrap { max-width: 800px; margin: 40px auto; padding: 0 20px; }
    .detail-back { display: inline-flex; align-items: center; gap: 6px; font-size: 13px; color: #1a6fa8; text-decoration: none; margin-bottom: 24px; font-family: 'DM Sans', sans-serif; }
    .detail-back:hover { color: #0a4d7c; }
    .detail-cat   { font-size: 11px; font-weight: 500; color: #1a6fa8; text-transform: uppercase; letter-spacing: .06em; margin-bottom: 10px; }
    .detail-title { font-family: 'Crimson Pro', serif; font-size: 32px; font-weight: 600; color: #0a4d7c; line-height: 1.3; margin-bottom: 14px; }
    .detail-meta  { font-size: 13px; color: #7a9bb0; margin-bottom: 24px; padding-bottom: 20px; border-bottom: 1px solid #e8f0f7; }
    .detail-meta strong { color: #0a4d7c; }
    .detail-thumb { width: 100%; max-height: 360px; object-fit: cover; border-radius: 12px; margin-bottom: 28px; }
    .detail-summary { font-size: 16px; color: #3a5a72; line-height: 1.7; font-style: italic; margin-bottom: 24px; padding: 16px 20px; background: #f0f8ff; border-left: 4px solid #1a6fa8; border-radius: 0 8px 8px 0; }
    .detail-content { font-size: 15px; color: #2a3f52; line-height: 1.85; white-space: pre-wrap; }
    .detail-content p { margin-bottom: 16px; }

    /* Related */
    .related-section { margin-top: 48px; padding-top: 32px; border-top: 1px solid #e8f0f7; }
    .related-title { font-family: 'Crimson Pro', serif; font-size: 20px; color: #0a4d7c; margin-bottom: 20px; }
    .related-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 16px; }
    @@media (max-width: 600px) { .related-grid { grid-template-columns: 1fr; } }
    .related-card { border: 1px solid #d4e8f5; border-radius: 10px; overflow: hidden; text-decoration: none; display: block; transition: transform .15s; }
    .related-card:hover { transform: translateY(-2px); }
    .related-img { height: 80px; display: flex; align-items: center; justify-content: center; font-size: 28px; overflow: hidden; }
    .related-img img { width: 100%; height: 100%; object-fit: cover; }
    .related-body { padding: 10px 12px; }
    .related-cat   { font-size: 10px; color: #1a6fa8; text-transform: uppercase; letter-spacing: .05em; margin-bottom: 4px; font-weight: 500; }
    .related-title2 { font-size: 12px; color: #0a4d7c; font-weight: 500; line-height: 1.4; }

    .not-found { text-align: center; padding: 80px 20px; color: #7a9bb0; }
</style>

<div class="detail-wrap">
    <a href="/News" class="detail-back">← Quay lại danh sách</a>
    <div id="articleDetail"><div class="not-found">Đang tải...</div></div>

    <!-- Bài viết liên quan -->
    <div class="related-section" id="relatedSection" style="display:none">
        <div class="related-title">Bài viết khác</div>
        <div class="related-grid" id="relatedGrid"></div>
    </div>
</div>

<script type="application/json" id="_articleData">@Html.Raw(ViewBag.ArticleJson ?? "null")</script>
<script type="application/json" id="_relatedData">@Html.Raw(ViewBag.RelatedJson ?? "[]")</script>

@section Scripts {
<script>
    var bgColors = ['linear-gradient(135deg,#e8f4fd,#d4ecf9)','linear-gradient(135deg,#fdf3d7,#fde8b0)','linear-gradient(135deg,#e6f7ef,#c9f0d8)','linear-gradient(135deg,#fdecea,#f9c9c9)'];
    var catIcons = {'Viêm xoang':'🤧','Thính học':'👂','Hồng — Thanh quản':'😴','TMH Nhi':'👶','Phẫu thuật nội soi':'🔬','Phòng ngừa':'💊','Khác':'📋'};

    try {
        var article = JSON.parse(document.getElementById('_articleData').textContent || 'null');
        if (!article) throw new Error("not found");

        document.title = article.title + ' — Phòng khám Tai Mũi Họng';

        var date = article.publishedAt ? new Date(article.publishedAt).toLocaleDateString('vi-VN', {day:'2-digit',month:'2-digit',year:'numeric'}) : '';
        var thumbHtml = article.thumbnail
            ? '<img class="detail-thumb" src="' + article.thumbnail + '" alt="' + article.title + '" />'
            : '';

        document.getElementById('articleDetail').innerHTML =
            '<div class="detail-cat">' + (article.category || '') + '</div>' +
            '<h1 class="detail-title">' + article.title + '</h1>' +
            '<div class="detail-meta">' +
                '<strong>' + (article.authorDegree ? article.authorDegree + '. ' : '') + (article.authorName || '') + '</strong>' +
                (date ? ' · ' + date : '') +
                (article.authorSpecialty ? ' · ' + article.authorSpecialty : '') +
            '</div>' +
            thumbHtml +
            '<div class="detail-summary">' + (article.summary || '') + '</div>' +
            '<div class="detail-content">' + (article.content || '').replace(/\n/g, '<br>') + '</div>';
    } catch(e) {
        document.getElementById('articleDetail').innerHTML =
            '<div class="not-found">Không tìm thấy bài viết hoặc bài chưa được đăng.</div>';
    }

    // Related articles
    try {
        var related = JSON.parse(document.getElementById('_relatedData').textContent || '[]');
        if (related.length) {
            document.getElementById('relatedSection').style.display = 'block';
            document.getElementById('relatedGrid').innerHTML = related.slice(0,3).map(function(a, i) {
                var bg  = bgColors[i % bgColors.length];
                var ico = catIcons[a.category] || '📋';
                var imgHtml = a.thumbnail
                    ? '<div class="related-img"><img src="' + a.thumbnail + '" onerror="this.parentElement.style.fontSize=\'28px\';this.parentElement.innerHTML=\'' + ico + '\'" /></div>'
                    : '<div class="related-img" style="background:' + bg + '">' + ico + '</div>';
                return '<a class="related-card" href="/News/Detail/' + a.id + '">' +
                    imgHtml +
                    '<div class="related-body">' +
                        '<div class="related-cat">' + a.category + '</div>' +
                        '<div class="related-title2">' + a.title + '</div>' +
                    '</div></a>';
            }).join('');
        }
    } catch(e) {}
</script>
}
