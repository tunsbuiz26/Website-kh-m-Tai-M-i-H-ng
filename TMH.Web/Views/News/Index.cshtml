@{
    ViewBag.Title = "Tin tức y tế — Phòng khám Tai Mũi Họng";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<style>
    .news-page-wrap { max-width: 1100px; margin: 40px auto; padding: 0 20px; }
    .news-page-header { margin-bottom: 32px; }
    .news-page-title { font-family: 'Crimson Pro', serif; font-size: 32px; font-weight: 600; color: #0a4d7c; margin-bottom: 6px; }
    .news-page-sub   { font-size: 14px; color: #7a9bb0; }

    /* Filter tabs */
    .cat-bar { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 28px; }
    .cat-btn { padding: 6px 16px; border-radius: 20px; border: 1.5px solid #d4e8f5; background: #fff; font-size: 12px; font-weight: 500; color: #3a5a72; cursor: pointer; font-family: 'DM Sans', sans-serif; transition: all .15s; }
    .cat-btn:hover, .cat-btn.active { background: #0a4d7c; color: #fff; border-color: #0a4d7c; }

    /* Grid */
    .news-grid-lg { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
    @@media (max-width: 768px) { .news-grid-lg { grid-template-columns: 1fr; } }
    @@media (max-width: 1024px) { .news-grid-lg { grid-template-columns: repeat(2, 1fr); } }

    .news-card-lg { border: 1px solid #d4e8f5; border-radius: 14px; overflow: hidden; cursor: pointer; transition: transform .15s, box-shadow .15s; background: #fff; text-decoration: none; display: block; }
    .news-card-lg:hover { transform: translateY(-3px); box-shadow: 0 8px 24px rgba(10,77,124,.1); }
    .news-img-lg { height: 160px; display: flex; align-items: center; justify-content: center; font-size: 48px; overflow: hidden; }
    .news-img-lg img { width: 100%; height: 100%; object-fit: cover; }
    .news-body-lg { padding: 16px 18px; }
    .news-cat-lg { font-size: 10px; font-weight: 500; color: #1a6fa8; text-transform: uppercase; letter-spacing: .06em; margin-bottom: 8px; }
    .news-title-lg { font-size: 15px; font-weight: 500; color: #0a4d7c; line-height: 1.5; margin-bottom: 8px; }
    .news-summary-lg { font-size: 12px; color: #7a9bb0; line-height: 1.6; margin-bottom: 10px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
    .news-meta-lg { font-size: 11px; color: #9ab0bf; }
    .empty-state { text-align: center; padding: 60px 20px; color: #7a9bb0; font-size: 14px; }
</style>

<div class="news-page-wrap">
    <div class="news-page-header">
        <div class="news-page-title">Kiến thức Tai · Mũi · Họng</div>
        <div class="news-page-sub">Thông tin chuyên sâu từ đội ngũ bác sĩ chuyên khoa TMH</div>
    </div>

    <!-- Filter theo chủ đề -->
    <div class="cat-bar" id="catBar">
        <button class="cat-btn active" onclick="filterCat('', this)">Tất cả</button>
        <button class="cat-btn" onclick="filterCat('Viêm xoang', this)">Viêm xoang</button>
        <button class="cat-btn" onclick="filterCat('Thính học', this)">Thính học</button>
        <button class="cat-btn" onclick="filterCat('Hồng — Thanh quản', this)">Họng — Thanh quản</button>
        <button class="cat-btn" onclick="filterCat('TMH Nhi', this)">TMH Nhi</button>
        <button class="cat-btn" onclick="filterCat('Phẫu thuật nội soi', this)">Phẫu thuật nội soi</button>
        <button class="cat-btn" onclick="filterCat('Phòng ngừa', this)">Phòng ngừa</button>
    </div>

    <!-- Grid bài viết -->
    <div class="news-grid-lg" id="newsGrid">
        <div class="empty-state" style="grid-column:1/-1">Đang tải...</div>
    </div>
</div>

@section Scripts {
<script>
    var allArticles = @Html.Raw(ViewBag.ArticlesJson ?? "[]");
    var bgColors = [
        'linear-gradient(135deg,#e8f4fd,#d4ecf9)',
        'linear-gradient(135deg,#fdf3d7,#fde8b0)',
        'linear-gradient(135deg,#e6f7ef,#c9f0d8)',
        'linear-gradient(135deg,#fdecea,#f9c9c9)',
        'linear-gradient(135deg,#f3e8fd,#e4c9f9)',
    ];
    var catIcons = {
        'Viêm xoang':'🤧','Thính học':'👂','Hồng — Thanh quản':'😴',
        'TMH Nhi':'👶','Phẫu thuật nội soi':'🔬','Phòng ngừa':'💊','Khác':'📋'
    };

    function renderArticles(articles) {
        var grid = document.getElementById('newsGrid');
        if (!articles.length) {
            grid.innerHTML = '<div class="empty-state" style="grid-column:1/-1">Không có bài viết nào trong chủ đề này.</div>';
            return;
        }
        grid.innerHTML = articles.map(function(a, i) {
            var bg  = bgColors[i % bgColors.length];
            var ico = catIcons[a.category] || '📋';
            var date = a.publishedAt ? new Date(a.publishedAt).toLocaleDateString('vi-VN') : '';
            var imgHtml = a.thumbnail
                ? '<div class="news-img-lg"><img src="' + a.thumbnail + '" onerror="this.parentElement.style.fontSize=\'48px\';this.parentElement.innerHTML=\'' + ico + '\'" /></div>'
                : '<div class="news-img-lg" style="background:' + bg + '">' + ico + '</div>';
            return '<a class="news-card-lg" href="/News/Detail/' + a.id + '">' +
                imgHtml +
                '<div class="news-body-lg">' +
                    '<div class="news-cat-lg">' + a.category + '</div>' +
                    '<div class="news-title-lg">' + a.title + '</div>' +
                    '<div class="news-summary-lg">' + (a.summary || '') + '</div>' +
                    '<div class="news-meta-lg">' + (a.authorName || '') + (date ? ' · ' + date : '') + '</div>' +
                '</div></a>';
        }).join('');
    }

    function filterCat(cat, btn) {
        document.querySelectorAll('.cat-btn').forEach(function(b){ b.classList.remove('active'); });
        btn.classList.add('active');
        var filtered = cat ? allArticles.filter(function(a){ return a.category === cat; }) : allArticles;
        renderArticles(filtered);
    }

    // Render ngay khi load
    renderArticles(allArticles);

    // Nếu có category từ URL
    var initCat = '@ViewBag.Category';
    if (initCat) {
        var btn = document.querySelector('.cat-btn[onclick*="' + initCat + '"]');
        if (btn) filterCat(initCat, btn);
    }
</script>
}
