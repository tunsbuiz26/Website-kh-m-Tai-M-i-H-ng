function loadAllArticles() {
    document.getElementById('articlesTable').innerHTML = '<div class="loading-row">Đang tải...</div>';
    fetch('/Admin/GetAllArticles')
    .then(function(r){ return r.json(); })
    .then(function(data) {
        if (!data.length) {
            document.getElementById('articlesTable').innerHTML = '<div class="loading-row">Chưa có bài viết nào.</div>';
            return;
        }
        var html = '<table class="data-table"><thead><tr>'
            + '<th>Tiêu đề</th><th>Tác giả</th><th>Chủ đề</th><th>Trạng thái</th><th>Ngày tạo</th><th>Thao tác</th>'
            + '</tr></thead><tbody>'
            + data.map(function(a) {
                var statusDisplay = a.StatusDisplay || a.statusDisplay || '';
                var isPub = statusDisplay === 'Đã đăng';
                return '<tr>'
                    + '<td><strong>' + (a.Title || a.title) + '</strong></td>'
                    + '<td>' + (a.AuthorName || a.authorName) + '</td>'
                    + '<td>' + (a.Category   || a.category) + '</td>'
                    + '<td><span class="badge ' + (isPub ? 'b-pub">✅ Đã đăng' : 'b-draft">📝 Nháp') + '</span></td>'
                    + '<td>' + new Date(a.CreatedAt || a.createdAt).toLocaleDateString('vi-VN') + '</td>'
                    + '<td style="display:flex;gap:6px;">'
                        + '<button class="btn-sm" onclick="toggleArticle(' + (a.Id||a.id) + ',this)">' + (isPub ? 'Gỡ bài' : '✅ Duyệt đăng') + '</button>'
                        + '<button class="btn-sm danger" onclick="adminDeleteArticle(' + (a.Id||a.id) + ')">🗑 Xóa</button>'
                    + '</td></tr>';
            }).join('')
            + '</tbody></table>';
        document.getElementById('articlesTable').innerHTML = html;
    })
    .catch(function(){ document.getElementById('articlesTable').innerHTML='<div class="loading-row">Lỗi tải dữ liệu</div>'; });
}
function toggleArticle(id, btn) {
    btn.disabled = true;
    fetch('/Admin/ToggleArticleStatus?id=' + id, { method:'POST', headers:{'RequestVerificationToken':csrf} })
    .then(function(r){ return r.json(); })
    .then(function(d) {
        if (d.Success || d.success) { showToast('Cập nhật thành công.', true); tabLoaded['articles']=false; loadAllArticles(); }
        else { showToast(d.Message || d.message || 'Lỗi.', false); btn.disabled=false; }
    });
}
function adminDeleteArticle(id) {
    if (!confirm('Xác nhận xóa bài viết này?')) return;
    fetch('/Admin/AdminDeleteArticle?id=' + id, { method:'POST', headers:{'RequestVerificationToken':csrf} })
    .then(function(r){ return r.json(); })
    .then(function(d) {
        if (d.Success || d.success) { showToast('Đã xóa bài viết.', true); loadAllArticles(); }
        else showToast(d.Message || d.message || 'Lỗi.', false);
    });
}

