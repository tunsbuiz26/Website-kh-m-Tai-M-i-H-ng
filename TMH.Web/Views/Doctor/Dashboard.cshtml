            <div class="phieu-line-inline">
                <div class="phieu-inline-seg">
                    <span class="phieu-line-label">– Vào khám lúc:&nbsp;</span>
                    <span class="phieu-line-value" id="ph_giokham" style="max-width:120px;"></span>
                </div>
                <div class="phieu-inline-seg">
                    <span class="phieu-line-label">&nbsp;ngày&nbsp;</span>
                    <span class="phieu-line-value" id="ph_ngay" style="max-width:30px;"></span>
                    <span class="phieu-line-label">&nbsp;tháng&nbsp;</span>
                    <span class="phieu-line-value" id="ph_thang" style="max-width:30px;"></span>
                    <span class="phieu-line-label">&nbsp;năm&nbsp;</span>
                    <span class="phieu-line-value" id="ph_nam" style="max-width:50px;"></span>
