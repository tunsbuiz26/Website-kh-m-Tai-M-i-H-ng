@Html.AntiForgeryToken()

@section Scripts {
<script>
    var csrfToken = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';

    // ── Sub-tab switching ─────────────────────────────────────────────
    function showDocTab(name, btn) {
        document.getElementById('panelSchedule').style.display = name === 'schedule' ? '' : 'none';
        document.getElementById('panelArticles').style.display = name === 'articles' ? '' : 'none';
        document.querySelectorAll('.sub-tab-btn').forEach(function(b) { b.classList.remove('active'); });
        btn.classList.add('active');
        if (name === 'articles' && !articlesLoaded) { articlesLoaded = true; loadMyArticles(); }
    }

    // ── Lịch khám: load theo ngày ────────────────────────────────────
    function loadSchedule() {
        var date = document.getElementById('filterDate').value;
        if (!date) return;
        fetch('/Doctor/GetAppointments?date=' + date)
            .then(function(r) { return r.json(); })
            .then(function(data) { renderCards(data); updateStats(data); })
            .catch(function() { alert('Lỗi kết nối'); });
    }

    function renderCards(data) {
        var list = document.getElementById('patientList');
        if (!data.length) {
            list.innerHTML = '<div class="empty-state">Không có lịch khám nào trong ngày này</div>';
            return;
        }

        var badgeMap = {
            'DaDen': 'badge-den', 'DangKham': 'badge-kham', 'HoanThanh': 'badge-hoan',
            'VangMat': 'badge-vang', 'DaHuy': 'badge-huy',
            'ChoXacNhan': 'badge-cho', 'DaXacNhan': 'badge-cho'
        };
        var cardMap = {
            'DaDen': 'card-waiting', 'DangKham': 'card-started',
            'HoanThanh': 'card-done', 'DaHuy': 'card-inactive', 'VangMat': 'card-inactive'
        };

        list.innerHTML = data.map(function(a, i) {
            var bc = badgeMap[a.status] || 'badge-cho';
            var cc = cardMap[a.status] || '';
            var noteHtml = a.note ? '<div class="patient-note">📝 ' + escHtml(a.note) + '</div>' : '';
            var diagExisting = a.diagnosis
                ? '<div class="diag-existing" id="diagExisting-' + a.id + '">🩺 Chuẩn đoán: ' + escHtml(a.diagnosis) + '</div>'
                : '<div class="diag-existing" id="diagExisting-' + a.id + '" style="display:none;"></div>';

            // Các nút bác sĩ theo đúng vòng đời
            var actionBtns = buildDoctorActionsAndStore(a);

            // Panel chuẩn đoán — nút bên trong thay đổi theo trạng thái
            var diagFooterBtns = '';
            if (a.status === 'DangKham') {
                diagFooterBtns =
                    '<button class="btn-save-diag" onclick="saveDiag(' + a.id + ', \'DangKham\')">💾 Lưu tạm</button>' +
                    '<button class="btn-done-diag" onclick="saveDiag(' + a.id + ', \'HoanThanh\')">✅ Lưu & Hoàn thành</button>';
            } else if (a.status === 'HoanThanh') {
                diagFooterBtns =
                    '<button class="btn-save-diag" onclick="saveDiag(' + a.id + ', \'HoanThanh\')">💾 Lưu cập nhật</button>';
            }

            var diagPanel =
                '<div class="diag-panel" id="diag-' + a.id + '">' +
                    '<label class="diag-label">Chuẩn đoán / Phác đồ điều trị</label>' +
                    '<textarea class="diag-input" id="diagText-' + a.id + '" placeholder="Nhập chuẩn đoán...">' + escHtml(a.diagnosis || '') + '</textarea>' +
                    '<div class="diag-footer">' +
                        '<button class="btn-cancel-diag" onclick="closeDiag(' + a.id + ')">Đóng</button>' +
                        diagFooterBtns +
                    '</div>' +
                    '<div id="diagMsg-' + a.id + '"></div>' +
                '</div>';

            return '<div class="patient-card ' + cc + '" id="card-' + a.id + '">' +
                '<div class="order-num">' + (i + 1) + '</div>' +
                '<div class="patient-info">' +
                    '<div class="patient-name">' + escHtml(a.patientName) + '</div>' +
                    '<div class="patient-meta">' +
                        '<span>🕐 ' + a.startTime + ' – ' + a.endTime + '</span>' +
                        '<span class="booking-code">' + a.bookingCode + '</span>' +
                        '<span><span class="badge ' + bc + '" id="badge-' + a.id + '">' + a.statusDisplay + '</span></span>' +
                    '</div>' +
                    noteHtml + diagExisting + diagPanel +
                '</div>' +
                '<div class="patient-actions">' + actionBtns + '</div>' +
                '</div>';
        }).join('');
    }

    // ── Thao tác bác sĩ theo đúng vòng đời ──────────────────────────
    // ChoXacNhan / DaXacNhan → chờ lễ tân check-in, bác sĩ không thao tác
    // DaDen                  → [Bắt đầu khám] → DangKham
    // DangKham               → [Ghi chuẩn đoán] + [Hoàn thành] → HoanThanh
    // HoanThanh              → [Sửa chuẩn đoán] (chỉ cập nhật diagnosis, không đổi status)
    // DaHuy / VangMat        → không thao tác
    function buildDoctorActions(a) {
        var s = a.status;
        if (s === 'ChoXacNhan' || s === 'DaXacNhan')
            return '<span class="lbl-staff">⏳ Chờ lễ tân check-in</span>';
        if (s === 'DaDen')
            return '<button class="btn-action btn-start" onclick="startExam(' + a.id + ')">▶ Bắt đầu khám</button>';
        if (s === 'DangKham')
            return '<button class="btn-action btn-diag" onclick="openDiag(' + a.id + ')">📋 Ghi chuẩn đoán</button>' +
                   '<button class="btn-action btn-done" onclick="finishExam(' + a.id + ')">✅ Hoàn thành</button>';
        if (s === 'HoanThanh')
            return '<button class="btn-action" style="background:#e8f4fd;color:#0a4d7c;border-color:#b8d8f0;" onclick="openDiag(' + a.id + ')">📋 Sửa chuẩn đoán</button>' +
                   '<button class="btn-action btn-print-phieu" onclick="openPhieu(allCards[' + a.id + '])">🖨 In phiếu</button>';
        return '<span style="font-size:11px;color:#bbb;">—</span>';
    }

    // ── Actions bác sĩ ───────────────────────────────────────────────
    function startExam(id) {
        // DaDen → DangKham: không cần confirm vì lễ tân đã xác nhận bệnh nhân có mặt
        postStatus(id, 'DangKham', null, function(ok, msg) {
            if (ok) loadSchedule();
            else alert(msg);
        });
    }

    function finishExam(id) {
        if (!confirm('Xác nhận hoàn thành khám cho bệnh nhân này?')) return;
        postStatus(id, 'HoanThanh', null, function(ok, msg) {
            if (ok) loadSchedule();
            else alert(msg);
        });
    }

    function openDiag(id)  {
        document.getElementById('diag-' + id).classList.add('open');
        document.getElementById('diagText-' + id).focus();
    }
    function closeDiag(id) { document.getElementById('diag-' + id).classList.remove('open'); }

    function saveDiag(id, newStatus) {
        var diagnosis = document.getElementById('diagText-' + id).value.trim();
        var msgEl = document.getElementById('diagMsg-' + id);
        msgEl.innerHTML = '';

        postStatus(id, newStatus, diagnosis, function(ok, msg) {
            if (ok) {
                msgEl.innerHTML = '<div class="msg-ok">✅ ' + msg + '</div>';
                // Cập nhật nhanh phần hiển thị chuẩn đoán trên card
                var existEl = document.getElementById('diagExisting-' + id);
                if (existEl && diagnosis) {
                    existEl.textContent = '🩺 Chuẩn đoán: ' + diagnosis;
                    existEl.style.display = '';
                }
                setTimeout(function() {
                    closeDiag(id);
                    if (newStatus === 'HoanThanh') loadSchedule();
                }, 1200);
            } else {
                msgEl.innerHTML = '<div class="msg-err">❌ ' + msg + '</div>';
            }
        });
    }

    function postStatus(id, status, diagnosis, cb) {
        var body = { appointmentId: id, newStatus: status };
        if (diagnosis) body.diagnosis = diagnosis;
        fetch('/Doctor/SaveDiagnosis', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': csrfToken },
            body: JSON.stringify(body)
        })
        .then(function(r) { return r.json(); })
        .then(function(data) { cb(data.success, data.message); })
        .catch(function() { cb(false, 'Lỗi kết nối'); });
    }

    function updateStats(data) {
        document.getElementById('statTotal').textContent = data.length;
        document.getElementById('statDen').textContent   = data.filter(function(a) { return a.status === 'DaDen'; }).length;
        document.getElementById('statKham').textContent  = data.filter(function(a) { return a.status === 'DangKham'; }).length;
        document.getElementById('statHoan').textContent  = data.filter(function(a) { return a.status === 'HoanThanh'; }).length;
    }

    // Escape HTML để tránh XSS khi render dữ liệu từ server vào innerHTML
    function escHtml(str) {
        return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }

    // ── Bài viết ─────────────────────────────────────────────────────
    var articlesLoaded = false;
    var currentArticleId = null;

    function loadMyArticles() {
        document.getElementById('articleList').innerHTML = '<div class="empty-state">Đang tải...</div>';
        fetch('/Doctor/GetMyArticles')
            .then(function(r) { return r.json(); })
            .then(function(data) {
                if (!data.length) {
                    document.getElementById('articleList').innerHTML =
                        '<div class="empty-state">Chưa có bài viết nào. Bấm "+ Viết bài mới" để bắt đầu.</div>';
                    return;
                }
                document.getElementById('articleList').innerHTML = data.map(function(a) {
                    var badge = a.statusDisplay === 'Đã đăng'
                        ? '<span class="badge-pub">Đã đăng</span>'
                        : '<span class="badge-draft">Nháp</span>';
                    var date = a.publishedAt
                        ? new Date(a.publishedAt).toLocaleDateString('vi-VN')
                        : new Date(a.createdAt).toLocaleDateString('vi-VN');
                    return '<div class="article-card">' +
                        '<div style="flex:1">' +
                            '<div class="article-card-title">' + escHtml(a.title) + '</div>' +
                            '<div class="article-card-meta">' + escHtml(a.category) + ' · ' + date + ' · ' + badge + '</div>' +
                        '</div>' +
                        '<div style="display:flex;gap:6px;flex-shrink:0;">' +
                            '<button class="btn-action btn-diag" onclick="openEditor(' + a.id + ')">Sửa</button>' +
                            '<button class="btn-action btn-vang" style="background:#fdecea;color:#a32d2d;border-color:#f5c6c6;" onclick="deleteArticle(' + a.id + ')">Xóa</button>' +
                        '</div></div>';
                }).join('');
            })
            .catch(function() { document.getElementById('articleList').innerHTML = '<div class="empty-state">Lỗi kết nối</div>'; });
    }

    function openEditor(id) {
        currentArticleId = id;
        document.getElementById('editorErr').style.display = 'none';
        document.getElementById('editorOk').style.display  = 'none';
        document.getElementById('editorTitleLabel').textContent = id ? 'Sửa bài viết' : 'Viết bài mới';
        ['artTitle','artCategory','artThumbnail','artSummary','artContent'].forEach(function(f) {
            document.getElementById(f).value = '';
        });
        document.getElementById('artImageFile').value = '';
        document.getElementById('thumbPreview').style.display    = 'none';
        document.getElementById('thumbPlaceholder').style.display = 'block';
        document.getElementById('uploadErr').style.display        = 'none';

        if (id) {
            fetch('/Doctor/GetArticleDetail?id=' + id)
                .then(function(r) { return r.json(); })
                .then(function(a) {
                    document.getElementById('artTitle').value     = a.title     || '';
                    document.getElementById('artCategory').value  = a.category  || '';
                    document.getElementById('artThumbnail').value = a.thumbnail || '';
                    document.getElementById('artSummary').value   = a.summary   || '';
                    document.getElementById('artContent').value   = a.content   || '';
                    if (a.thumbnail) {
                        document.getElementById('thumbPreview').src           = a.thumbnail;
                        document.getElementById('thumbPreview').style.display    = 'block';
                        document.getElementById('thumbPlaceholder').style.display = 'none';
                    }
                });
        }
        document.getElementById('editorModal').classList.add('open');
    }

    function previewAndUpload(input) {
        var file = input.files[0];
        if (!file) return;
        var reader = new FileReader();
        reader.onload = function(e) {
            document.getElementById('thumbPreview').src = e.target.result;
            document.getElementById('thumbPreview').style.display    = 'block';
            document.getElementById('thumbPlaceholder').style.display = 'none';
        };
        reader.readAsDataURL(file);

        document.getElementById('uploadProgress').style.display = 'block';
        document.getElementById('uploadErr').style.display = 'none';
        var formData = new FormData();
        formData.append('file', file);
        fetch('/Doctor/UploadArticleImage', {
            method: 'POST',
            headers: { 'RequestVerificationToken': csrfToken },
            body: formData
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            document.getElementById('uploadProgress').style.display = 'none';
            if (data.success) {
                document.getElementById('artThumbnail').value = data.url;
            } else {
                document.getElementById('uploadErr').textContent = data.message;
                document.getElementById('uploadErr').style.display = 'block';
                document.getElementById('thumbPreview').style.display    = 'none';
                document.getElementById('thumbPlaceholder').style.display = 'block';
            }
        })
        .catch(function() {
            document.getElementById('uploadProgress').style.display = 'none';
            document.getElementById('uploadErr').textContent = 'Lỗi kết nối khi tải ảnh.';
            document.getElementById('uploadErr').style.display = 'block';
        });
    }

    function closeEditor() { document.getElementById('editorModal').classList.remove('open'); }

    function saveArticle(publish) {
        var title    = document.getElementById('artTitle').value.trim();
        var category = document.getElementById('artCategory').value;
        var summary  = document.getElementById('artSummary').value.trim();
        var content  = document.getElementById('artContent').value.trim();
        var errEl    = document.getElementById('editorErr');
        errEl.style.display = 'none';

        if (!title)    { errEl.textContent = 'Vui lòng nhập tiêu đề.';  errEl.style.display = 'block'; return; }
        if (!category) { errEl.textContent = 'Vui lòng chọn chủ đề.';   errEl.style.display = 'block'; return; }
        if (!summary)  { errEl.textContent = 'Vui lòng nhập tóm tắt.';  errEl.style.display = 'block'; return; }
        if (!content)  { errEl.textContent = 'Vui lòng nhập nội dung.'; errEl.style.display = 'block'; return; }

        var url = currentArticleId ? '/Doctor/UpdateArticle?id=' + currentArticleId : '/Doctor/CreateArticle';
        var btn = publish ? document.getElementById('savePublishBtn') : document.getElementById('saveDraftBtn');
        btn.disabled = true;

        fetch(url, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': csrfToken },
            body: JSON.stringify({
                title: title, category: category, summary: summary, content: content, publish: publish,
                thumbnail: document.getElementById('artThumbnail').value.trim() || null
            })
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            if (data.success) {
                document.getElementById('editorOk').textContent = data.message;
                document.getElementById('editorOk').style.display = 'block';
                setTimeout(function() { closeEditor(); loadMyArticles(); }, 1200);
            } else {
                errEl.textContent = data.message || 'Có lỗi xảy ra.';
                errEl.style.display = 'block';
            }
        })
        .catch(function() { errEl.textContent = 'Lỗi kết nối.'; errEl.style.display = 'block'; })
        .finally(function() { btn.disabled = false; });
    }

    function deleteArticle(id) {
        if (!confirm('Xác nhận xóa bài viết này?')) return;
        fetch('/Doctor/DeleteArticle?id=' + id, {
            method: 'POST', headers: { 'RequestVerificationToken': csrfToken }
        })
        .then(function(r) { return r.json(); })
        .then(function(data) { if (data.success) loadMyArticles(); else alert(data.message); });
    }
    // ── Phiếu khám bệnh (chỉ bác sĩ) ───────────────────────────────
    // allCards lưu map id → appointment object khi AJAX render
    var allCards = {};

    function buildDoctorActionsAndStore(a) {
        allCards[a.id] = a;  // lưu lại để openPhieu truy xuất
        return buildDoctorActions(a);
    }

    function openPhieuStatic(obj) { fillPhieu(obj); }
    function openPhieu(a)         { if (a) fillPhieu(a); }

    function fillPhieu(a) {
        var d = new Date(a.workDate || a.WorkDate);
        var ngay  = d.getDate().toString().padStart(2,'0');
        var thang = (d.getMonth()+1).toString().padStart(2,'0');
        var nam   = d.getFullYear();
        var ngaykham = d.toLocaleDateString('vi-VN', {weekday:'long', day:'2-digit', month:'2-digit', year:'numeric'});

        var today = new Date();
        var ngayky = 'Ngày ' + today.getDate() + ' tháng ' + (today.getMonth()+1) + ' năm ' + today.getFullYear();

        setText('ph_code',       a.bookingCode  || a.BookingCode  || '');
        setText('ph_ngaykham',   ngaykham);
        setText('ph_hoten',      a.patientName  || a.PatientName  || '');
        setText('ph_malich',     a.bookingCode  || a.BookingCode  || '');
        setText('ph_bacsi',   'BS. ' + (a.doctorName  || a.DoctorName  || ''));
        setText('ph_chuyenkhoa', a.specialty    || a.Specialty    || 'Tai Mũi Họng');
        setText('ph_giokham',   (a.startTime    || a.StartTime    || '') + ' – ' + (a.endTime || a.EndTime || ''));
        setText('ph_ngay',       ngay);
        setText('ph_thang',      thang);
        setText('ph_nam',        nam);
        setText('ph_ghichu',     a.note || a.Note || '(Không có ghi chú)');
        setText('ph_chandoan',   a.diagnosis || a.Diagnosis || 'Chưa có kết quả chẩn đoán.');
        setText('ph_ngayky',     ngayky);
        setText('ph_bsSign',  'BS. ' + (a.doctorName || a.DoctorName || ''));

        document.getElementById('phieuModal').classList.add('open');
    }

    function closePhieu() {
        document.getElementById('phieuModal').classList.remove('open');
    }

    function setText(id, val) {
        var el = document.getElementById(id);
        if (el) el.textContent = val || '';
    }

</script>
}
