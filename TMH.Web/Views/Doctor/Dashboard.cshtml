            <!-- Chữ ký -->
            <div class="phieu-chukybottom">
                <div class="phieu-chuky-col">
                    <div class="phieu-chuky-title">Trưởng khoa điều trị</div>
                    <div class="phieu-chuky-note">(Ký, ghi rõ họ tên)</div>
                    <div class="phieu-chuky-space"></div>
                    <div class="phieu-chuky-name">&nbsp;</div>
                </div>
                <div class="phieu-chuky-col">
                    <div class="phieu-chuky-title">Bác sĩ điều trị</div>
                    <div class="phieu-chuky-note">(Ký, ghi rõ họ tên)</div>
