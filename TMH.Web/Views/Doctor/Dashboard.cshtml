@model List<TMH.Shared.DTOs.AppointmentDetailDto>
@{
    ViewBag.Title = "Dashboard Bác sĩ";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
<style>
    .doc-wrap { max-width: 1000px; margin: 32px auto; padding: 0 20px; }
    .page-title { font-family: 'Crimson Pro', serif; font-size: 26px; font-weight: 600; color: #0a4d7c; }
    .page-sub   { font-size: 13px; color: #7a9bb0; margin-top: 2px; }

    /* Sub-tabs */
    .sub-tab-bar { display: flex; border-bottom: 2px solid #d4e8f5; margin-bottom: 20px; }
    .sub-tab-btn { padding: 10px 20px; font-size: 13px; font-weight: 500; color: #7a9bb0; background: none; border: none; cursor: pointer; border-bottom: 2px solid transparent; margin-bottom: -2px; font-family: 'DM Sans', sans-serif; transition: all .15s; }
    .sub-tab-btn:hover { color: #0a4d7c; }
    .sub-tab-btn.active { color: #0a4d7c; border-bottom-color: #0a4d7c; }

    /* Toolbar */
    .toolbar { display: flex; gap: 10px; align-items: center; flex-wrap: wrap; background: #fff; border: 1px solid #d4e8f5; border-radius: 12px; padding: 14px 18px; margin-bottom: 20px; }
    .toolbar label { font-size: 12px; font-weight: 500; color: #3a5a72; text-transform: uppercase; letter-spacing: .04em; }
    .toolbar input[type=date] { height: 36px; border: 1px solid #d4e8f5; border-radius: 8px; padding: 0 10px; font-size: 13px; color: #0d2d44; outline: none; font-family: 'DM Sans', sans-serif; }
    .btn-load { height: 36px; padding: 0 18px; background: #0a4d7c; color: #fff; border: none; border-radius: 8px; font-size: 13px; font-weight: 500; cursor: pointer; font-family: 'DM Sans', sans-serif; }
    .btn-load:hover { background: #1a6fa8; }

    /* Stats */
    .stats-bar { display: flex; gap: 12px; margin-bottom: 20px; flex-wrap: wrap; }
    .stat-card { flex: 1; min-width: 110px; background: #fff; border: 1px solid #d4e8f5; border-radius: 10px; padding: 12px 16px; text-align: center; }
    .stat-num { font-size: 24px; font-weight: 700; color: #0a4d7c; }
    .stat-lbl { font-size: 11px; color: #7a9bb0; margin-top: 2px; }
    .stat-card.den  .stat-num { color: #004085; }
    .stat-card.kham .stat-num { color: #155724; }
    .stat-card.hoan .stat-num { color: #383d41; }

    /* Patient cards */
    .patient-list { display: flex; flex-direction: column; gap: 12px; }
    .patient-card { background: #fff; border: 1px solid #d4e8f5; border-radius: 14px; padding: 18px 20px; display: flex; gap: 16px; align-items: flex-start; transition: border-color .15s; }
    .patient-card:hover { border-color: #1a6fa8; }
    .patient-card.card-waiting  { border-left: 4px solid #b8d8f0; }
    .patient-card.card-started  { border-left: 4px solid #2d7a52; }
    .patient-card.card-done     { border-left: 4px solid #aab8c2; opacity: .8; }
    .patient-card.card-inactive { border-left: 4px solid #f5c6c6; opacity: .7; }

    .order-num { width: 36px; height: 36px; border-radius: 50%; background: #0a4d7c; color: #fff; font-size: 14px; font-weight: 600; display: flex; align-items: center; justify-content: center; flex-shrink: 0; margin-top: 2px; }
    .patient-info { flex: 1; }
    .patient-name { font-size: 15px; font-weight: 500; color: #0a4d7c; margin-bottom: 4px; }
    .patient-meta { display: flex; flex-wrap: wrap; gap: 12px; font-size: 12px; color: #7a9bb0; margin-bottom: 8px; }
    .booking-code { font-family: monospace; font-size: 11px; background: #f0f8ff; padding: 2px 8px; border-radius: 4px; color: #1a6fa8; }
    .patient-note { font-size: 12px; color: #555; background: #fafafa; border-left: 3px solid #d4e8f5; padding: 6px 10px; border-radius: 0 6px 6px 0; margin-bottom: 8px; }

    .badge { display: inline-block; font-size: 11px; font-weight: 500; padding: 3px 10px; border-radius: 20px; white-space: nowrap; }
    .badge-den  { background: #cce5ff; color: #004085; }
    .badge-kham { background: #d4edda; color: #155724; }
    .badge-hoan { background: #e2e3e5; color: #383d41; }
    .badge-cho  { background: #fff3cd; color: #856404; }
    .badge-vang { background: #fdecea; color: #a32d2d; }
    .badge-huy  { background: #f8d7da; color: #721c24; }

    /* Actions — bác sĩ */
    .patient-actions { display: flex; flex-direction: column; gap: 8px; align-items: flex-end; min-width: 160px; }
    .btn-action { height: 30px; padding: 0 12px; border-radius: 7px; font-size: 12px; font-weight: 500; cursor: pointer; border: 1px solid; font-family: 'DM Sans', sans-serif; white-space: nowrap; transition: all .15s; }

    /* Bắt đầu khám: DaDen → DangKham */
    .btn-start { background: #cce5ff; color: #004085; border-color: #99caef; }
    .btn-start:hover { background: #004085; color: #fff; }

    /* Hoàn thành: DangKham → HoanThanh */
    .btn-done  { background: #d4edda; color: #155724; border-color: #b8ddc4; }
    .btn-done:hover { background: #155724; color: #fff; }

    /* Ghi chuẩn đoán (mở panel) */
    .btn-diag  { background: #0a4d7c; color: #fff; border-color: #0a4d7c; }
    .btn-diag:hover { background: #1a6fa8; }

    .lbl-staff { font-size: 11px; color: #7a9bb0; font-style: italic; }

    /* Diagnosis panel */
    .diag-panel { display: none; margin-top: 12px; background: #f8fbff; border: 1px solid #d4e8f5; border-radius: 10px; padding: 16px; }
    .diag-panel.open { display: block; }
    .diag-label { font-size: 11px; font-weight: 500; color: #3a5a72; text-transform: uppercase; letter-spacing: .04em; margin-bottom: 5px; display: block; }
    .diag-input { width: 100%; border: 1px solid #d4e8f5; border-radius: 8px; padding: 8px 12px; font-size: 13px; outline: none; font-family: 'DM Sans', sans-serif; resize: vertical; min-height: 70px; box-sizing: border-box; }
    .diag-input:focus { border-color: #1a6fa8; }
    .diag-footer { display: flex; gap: 8px; margin-top: 10px; justify-content: flex-end; }
    .btn-save-diag { height: 32px; padding: 0 16px; background: #0a4d7c; color: #fff; border: none; border-radius: 7px; font-size: 12px; font-weight: 500; cursor: pointer; font-family: 'DM Sans', sans-serif; }
    .btn-save-diag:hover { background: #1a6fa8; }
    .btn-done-diag { height: 32px; padding: 0 16px; background: #2d7a52; color: #fff; border: none; border-radius: 7px; font-size: 12px; font-weight: 500; cursor: pointer; font-family: 'DM Sans', sans-serif; }
    .btn-done-diag:hover { background: #1e5c3a; }
    .btn-cancel-diag { height: 32px; padding: 0 14px; background: #f5f5f5; color: #555; border: none; border-radius: 7px; font-size: 12px; cursor: pointer; font-family: 'DM Sans', sans-serif; }
    .diag-existing { font-size: 12px; color: #2d7a52; background: #f0faf4; border-left: 3px solid #2d7a52; padding: 6px 10px; border-radius: 0 6px 6px 0; margin-bottom: 8px; }
    .msg-ok  { font-size: 12px; color: #2d7a52; margin-top: 6px; }
    .msg-err { font-size: 12px; color: #c0392b; margin-top: 6px; }
    .empty-state { text-align: center; padding: 48px 20px; color: #7a9bb0; font-size: 13px; background: #fff; border: 1px solid #d4e8f5; border-radius: 14px; }

    /* Articles */
    .article-card { background: #fff; border: 1px solid #d4e8f5; border-radius: 12px; padding: 16px 18px; display: flex; justify-content: space-between; align-items: center; gap: 12px; margin-bottom: 10px; }
    .article-card:hover { border-color: #1a6fa8; }
    .article-card-title { font-size: 14px; font-weight: 500; color: #0a4d7c; margin-bottom: 4px; }
    .article-card-meta  { font-size: 11px; color: #7a9bb0; }
    .badge-pub   { background: #d4edda; color: #155724; font-size: 11px; padding: 2px 8px; border-radius: 10px; font-weight: 500; }
    .badge-draft { background: #e2e3e5; color: #383d41; font-size: 11px; padding: 2px 8px; border-radius: 10px; font-weight: 500; }

    /* Editor modal */
    .editor-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,.5); z-index: 9999; align-items: flex-start; justify-content: center; padding: 20px; overflow-y: auto; }
    .editor-overlay.open { display: flex; }
    .editor-box { background: #fff; border-radius: 16px; padding: 28px; width: 720px; max-width: 95vw; margin: auto; }
    .editor-title-lbl { font-size: 16px; font-weight: 600; color: #0a4d7c; margin-bottom: 20px; }
    .editor-form-row { display: flex; gap: 12px; margin-bottom: 14px; flex-wrap: wrap; }
    .editor-form-group { flex: 1; min-width: 200px; }
    .editor-label { font-size: 11px; font-weight: 500; color: #3a5a72; text-transform: uppercase; letter-spacing: .04em; display: block; margin-bottom: 5px; }
    .editor-input { width: 100%; border: 1px solid #d4e8f5; border-radius: 8px; padding: 8px 12px; font-size: 13px; outline: none; font-family: 'DM Sans', sans-serif; box-sizing: border-box; height: 38px; }
    .editor-input:focus { border-color: #1a6fa8; }
    textarea.editor-input { height: auto; min-height: 80px; resize: vertical; }
    #artContent { min-height: 200px; }
    .editor-footer { display: flex; gap: 10px; margin-top: 20px; }

    /* ── Nút in phiếu (bác sĩ) ────────────────────────────────── */
    .btn-print-phieu {
        height: 30px; padding: 0 12px;
        background: #c9a227; color: #fff;
        border: none; border-radius: 7px; font-size: 12px;
        font-weight: 500; cursor: pointer;
        font-family: 'DM Sans', sans-serif;
        white-space: nowrap; transition: background .15s;
    }
    .btn-print-phieu:hover { background: #a8841e; }

    /* ── Modal phiếu khám bệnh ─────────────────────────────────── */
    .phieu-modal-overlay {
        display: none; position: fixed; inset: 0;
        background: rgba(0,0,0,.55); z-index: 9999;
        align-items: flex-start; justify-content: center;
        overflow-y: auto; padding: 24px 16px;
        backdrop-filter: blur(3px);
    }
    .phieu-modal-overlay.open { display: flex; }

    .phieu-controls {
        display: flex; gap: 10px; justify-content: flex-end;
        max-width: 680px; margin: 0 auto 12px;
    }
    .phieu-btn-print {
        height: 38px; padding: 0 20px;
        background: #0a4d7c; color: #fff;
        border: none; border-radius: 9px; font-size: 13px;
        cursor: pointer; font-family: 'DM Sans', sans-serif;
        display: flex; align-items: center; gap: 6px;
    }
    .phieu-btn-close {
        height: 38px; padding: 0 18px;
        background: rgba(255,255,255,.9); color: #555;
        border: none; border-radius: 9px; font-size: 13px;
        cursor: pointer; font-family: 'DM Sans', sans-serif;
    }

    /* Tờ phiếu kiểu giấy tờ y tế */
    .phieu-sheet {
        background: #fff;
        width: 680px; max-width: 100%;
        border-radius: 4px;
        padding: 36px 44px;
        font-family: 'Times New Roman', Times, serif;
        margin: 0 auto;
        box-shadow: 0 20px 60px rgba(0,0,0,.25);
        border: 1px solid #ccc;
        position: relative;
    }

    /* Quốc hiệu */
    .phieu-quochieu {
        text-align: center;
        margin-bottom: 18px;
    }
    .phieu-quochieu-top {
        font-size: 13px; font-weight: bold;
        text-transform: uppercase; letter-spacing: .04em;
    }
    .phieu-quochieu-sub {
        font-size: 13px; font-weight: bold;
        margin-top: 2px;
    }
    .phieu-quochieu-doc {
        font-size: 12px; font-style: italic;
        border-bottom: 1px solid #333;
        display: inline-block;
        padding-bottom: 2px;
        margin-top: 2px;
    }

    /* Header 2 cột */
    .phieu-header-row {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        border-bottom: 1.5px solid #333;
        padding-bottom: 14px;
        margin-bottom: 18px;
    }
    .phieu-benh-vien {
        font-size: 12px;
        font-weight: bold;
        text-transform: uppercase;
        line-height: 1.5;
    }
    .phieu-benh-vien-sub {
        font-size: 11px;
        font-weight: normal;
        text-transform: none;
        color: #333;
        margin-top: 3px;
        line-height: 1.5;
    }

    /* Tên phiếu */
    .phieu-ten {
        text-align: center;
        font-size: 20px;
        font-weight: bold;
        text-transform: uppercase;
        letter-spacing: .06em;
        margin-bottom: 20px;
    }

    /* Các dòng thông tin kiểu gạch chân */
    .phieu-line {
        font-size: 13px;
        margin-bottom: 10px;
        display: flex;
        align-items: baseline;
        gap: 0;
        line-height: 1.8;
    }
    .phieu-line-label {
        flex-shrink: 0;
        font-weight: normal;
    }
    .phieu-line-value {
        flex: 1;
        border-bottom: 1px solid #333;
        min-width: 60px;
        padding: 0 4px;
        font-weight: 500;
    }
    .phieu-line-unit {
        flex-shrink: 0;
        margin-left: 6px;
    }

    /* Dòng inline (cùng hàng nhiều field) */
    .phieu-line-inline {
        font-size: 13px;
        margin-bottom: 10px;
        display: flex;
        gap: 16px;
        flex-wrap: wrap;
        line-height: 1.8;
    }
    .phieu-inline-seg {
        display: flex;
        align-items: baseline;
        gap: 0;
        flex: 1;
        min-width: 120px;
    }

    /* Phần chuẩn đoán */
    .phieu-chandoan-box {
        border: 1.5px solid #333;
        border-radius: 2px;
        min-height: 60px;
        padding: 8px 12px;
        font-size: 13px;
        line-height: 1.7;
        margin-top: 4px;
        margin-bottom: 14px;
        color: #0a2d4a;
        font-weight: 500;
    }

    /* Chữ ký */
    .phieu-chukybottom {
        display: flex;
        justify-content: space-between;
        margin-top: 28px;
    }
    .phieu-chuky-col {
        text-align: center;
        min-width: 150px;
    }
    .phieu-chuky-title {
        font-size: 13px; font-weight: bold;
        text-transform: uppercase;
    }
    .phieu-chuky-note {
        font-size: 11px; font-style: italic;
        color: #555; margin-top: 2px;
    }
    .phieu-chuky-space { height: 64px; }
    .phieu-chuky-name {
        font-size: 13px; font-weight: bold;
        border-top: 1px solid #333;
        padding-top: 4px;
        display: inline-block;
        min-width: 130px;
    }

    /* Ngày tháng bên phải */
    .phieu-ngay {
        text-align: right;
        font-size: 12px;
        font-style: italic;
        margin-bottom: 4px;
    }

    @@media print {
        body * { visibility: hidden; }
        .phieu-sheet, .phieu-sheet * { visibility: visible; }
        .phieu-sheet {
            position: fixed; left: 0; top: 0;
            width: 100%; padding: 20px 32px;
            border-radius: 0; box-shadow: none; border: none;
        }
        .phieu-controls { display: none !important; }
    }
</style>
}

<div class="doc-wrap">
    <div style="margin-bottom: 20px;">
        <div class="page-title">Trang của tôi</div>
        <div class="page-sub">BS. @ViewBag.UserName — Phòng khám Tai Mũi Họng</div>
    </div>

    <!-- Sub-tabs -->
    <div class="sub-tab-bar">
        <button class="sub-tab-btn active" onclick="showDocTab('schedule', this)">📅 Lịch khám</button>
        <button class="sub-tab-btn" onclick="showDocTab('articles', this)">📝 Bài viết y tế</button>
    </div>

    <!-- ── Panel: Lịch khám ─────────────────────────────────────── -->
    <div id="panelSchedule">
        <div class="toolbar">
            <label>Ngày khám</label>
            <input type="date" id="filterDate" value="@DateTime.Today.ToString("yyyy-MM-dd")" />
            <button class="btn-load" onclick="loadSchedule()">Xem lịch</button>
            <span style="margin-left:auto;font-size:13px;color:#7a9bb0;">@ViewBag.TodayDate</span>
        </div>

        <div class="stats-bar">
            <div class="stat-card">
                <div class="stat-num" id="statTotal">@Model.Count</div>
                <div class="stat-lbl">Tổng lịch</div>
            </div>
            <div class="stat-card den">
                <div class="stat-num" id="statDen">@Model.Count(a => a.Status == "DaDen")</div>
                <div class="stat-lbl">Đã đến — chờ khám</div>
            </div>
            <div class="stat-card kham">
                <div class="stat-num" id="statKham">@Model.Count(a => a.Status == "DangKham")</div>
                <div class="stat-lbl">Đang khám</div>
            </div>
            <div class="stat-card hoan">
                <div class="stat-num" id="statHoan">@Model.Count(a => a.Status == "HoanThanh")</div>
                <div class="stat-lbl">Hoàn thành</div>
            </div>
        </div>

        <div class="patient-list" id="patientList">
            @if (!Model.Any())
            {
                <div class="empty-state">Không có lịch khám nào hôm nay</div>
            }
            else
            {
                @for (int i = 0; i < Model.Count; i++)
                {
                    var a = Model[i];
                    var badgeClass = a.Status switch {
                        "DaDen"     => "badge-den",
                        "DangKham"  => "badge-kham",
                        "HoanThanh" => "badge-hoan",
                        "VangMat"   => "badge-vang",
                        "DaHuy"     => "badge-huy",
                        _           => "badge-cho"
                    };
                    var cardClass = a.Status switch {
                        "DaDen"     => "card-waiting",
                        "DangKham"  => "card-started",
                        "HoanThanh" => "card-done",
                        "DaHuy" or "VangMat" => "card-inactive",
                        _           => ""
                    };
                    <div class="patient-card @cardClass" id="card-@a.Id">
                        <div class="order-num">@(i + 1)</div>
                        <div class="patient-info">
                            <div class="patient-name">@a.PatientName</div>
                            <div class="patient-meta">
                                <span>🕐 @a.StartTime – @a.EndTime</span>
                                <span class="booking-code">@a.BookingCode</span>
                                <span><span class="badge @badgeClass" id="badge-@a.Id">@a.StatusDisplay</span></span>
                            </div>
                            @if (!string.IsNullOrEmpty(a.Note))
                            {
                                <div class="patient-note">📝 @a.Note</div>
                            }
                            @if (!string.IsNullOrEmpty(a.Diagnosis))
                            {
                                <div class="diag-existing" id="diagExisting-@a.Id">🩺 Chuẩn đoán: @a.Diagnosis</div>
                            }
                            else
                            {
                                <div class="diag-existing" id="diagExisting-@a.Id" style="display:none;"></div>
                            }

                            <!-- Panel ghi chuẩn đoán — chỉ hiện khi bấm nút -->
                            <div class="diag-panel" id="diag-@a.Id">
                                <label class="diag-label">Chuẩn đoán / Phác đồ điều trị</label>
                                <textarea class="diag-input" id="diagText-@a.Id"
                                    placeholder="Nhập chuẩn đoán, phác đồ điều trị...">@a.Diagnosis</textarea>
                                <div class="diag-footer">
                                    <button class="btn-cancel-diag" onclick="closeDiag(@a.Id)">Đóng</button>
                                    @if (a.Status == "DangKham")
                                    {
                                        <!-- Đang khám: lưu tạm hoặc lưu và hoàn thành -->
                                        <button class="btn-save-diag" onclick="saveDiag(@a.Id, 'DangKham')">💾 Lưu tạm</button>
                                        <button class="btn-done-diag" onclick="saveDiag(@a.Id, 'HoanThanh')">✅ Lưu & Hoàn thành</button>
                                    }
                                </div>
                                <div id="diagMsg-@a.Id"></div>
                            </div>
                        </div>

                        <!-- Thao tác bác sĩ theo đúng vòng đời -->
                        <div class="patient-actions">
                            @if (a.Status == "DaDen")
                            {
                                <!-- Bệnh nhân đã check-in: bác sĩ bắt đầu khám -->
                                <button class="btn-action btn-start" onclick="startExam(@a.Id)">▶ Bắt đầu khám</button>
                            }
                            @if (a.Status == "DangKham")
                            {
                                <!-- Đang khám: ghi chuẩn đoán + hoàn thành -->
                                <button class="btn-action btn-diag" onclick="openDiag(@a.Id)">📋 Ghi chuẩn đoán</button>
                                <button class="btn-action btn-done" onclick="finishExam(@a.Id)">✅ Hoàn thành</button>
                            }
                            @if (a.Status == "ChoXacNhan" || a.Status == "DaXacNhan")
                            {
                                <span class="lbl-staff">⏳ Chờ lễ tân check-in</span>
                            }
                            @if (a.Status == "HoanThanh")
                            {
                                <!-- Hoàn thành: sửa chuẩn đoán + in phiếu -->
                                <button class="btn-action btn-diag" onclick="openDiag(@a.Id)" style="background:#e8f4fd;color:#0a4d7c;border-color:#b8d8f0;">📋 Sửa chuẩn đoán</button>
                                <button class="btn-action btn-print-phieu" onclick='openPhieuStatic(@Html.Raw(System.Text.Json.JsonSerializer.Serialize(new {
                                    id = a.Id, bookingCode = a.BookingCode, patientName = a.PatientName,
                                    doctorName = a.DoctorName, specialty = a.Specialty,
                                    workDate = a.WorkDate, startTime = a.StartTime, endTime = a.EndTime,
                                    diagnosis = a.Diagnosis ?? "", note = a.Note ?? ""
                                })))'>🖨 In phiếu</button>
                            }
                        </div>
                    </div>
                }
            }
        </div>
    </div>

    <!-- ── Panel: Bài viết ─────────────────────────────────────── -->
    <div id="panelArticles" style="display:none;">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;">
            <div style="font-size:14px;font-weight:500;color:#0a4d7c;">Bài viết của tôi</div>
            <button onclick="openEditor(null)" class="btn-load">+ Viết bài mới</button>
        </div>
        <div id="articleList">
            <div class="empty-state">Đang tải...</div>
        </div>
    </div>
</div>

<!-- ── Modal Editor ─────────────────────────────────────────── -->
<div class="editor-overlay" id="editorModal" onclick="if(event.target===this)closeEditor()">
    <div class="editor-box">
        <div class="editor-title-lbl" id="editorTitleLabel">Viết bài mới</div>

        <div id="editorErr" style="background:#fdecea;border:1px solid #f5c6c6;border-radius:8px;padding:10px 14px;margin-bottom:12px;color:#c0392b;font-size:12px;display:none;"></div>
        <div id="editorOk"  style="background:#e8f5e9;border:1px solid #a5d6a7;border-radius:8px;padding:10px 14px;margin-bottom:12px;color:#2d7a52;font-size:12px;display:none;"></div>

        <div class="editor-form-row">
            <div style="flex:1;">
                <label class="editor-label">Tiêu đề *</label>
                <input class="editor-input" id="artTitle" placeholder="Tiêu đề bài viết..." />
            </div>
        </div>

        <div class="editor-form-row">
            <div class="editor-form-group">
                <label class="editor-label">Chủ đề *</label>
                <select class="editor-input" id="artCategory">
                    <option value="">-- Chọn chủ đề --</option>
                    <option>Viêm xoang</option>
                    <option>Thính học</option>
                    <option>Hồng — Thanh quản</option>
                    <option>TMH Nhi</option>
                    <option>Phẫu thuật nội soi</option>
                    <option>Phòng ngừa</option>
                    <option>Khác</option>
                </select>
            </div>
            <div class="editor-form-group">
                <label class="editor-label">Ảnh thumbnail</label>
                <div style="border:1.5px dashed #d4e8f5;border-radius:8px;padding:10px;text-align:center;cursor:pointer;background:#fafcff;" onclick="document.getElementById('artImageFile').click()">
                    <img id="thumbPreview" src="" alt="" style="max-width:100%;max-height:100px;border-radius:6px;display:none;margin-bottom:6px;" />
                    <div id="thumbPlaceholder" style="font-size:12px;color:#7a9bb0;padding:6px 0;">
                        🖼 Bấm để chọn ảnh<br><small>JPG, PNG, WebP — tối đa 5MB</small>
                    </div>
                    <input type="file" id="artImageFile" accept="image/*" style="display:none" onchange="previewAndUpload(this)" />
                </div>
                <input type="hidden" id="artThumbnail" />
                <div id="uploadProgress" style="font-size:11px;color:#7a9bb0;margin-top:4px;display:none;">Đang tải lên...</div>
                <div id="uploadErr" style="font-size:11px;color:#c0392b;margin-top:4px;display:none;"></div>
            </div>
        </div>

        <div style="margin-bottom:14px;">
            <label class="editor-label">Tóm tắt *</label>
            <textarea class="editor-input" id="artSummary" rows="3"
                placeholder="Mô tả ngắn gọn nội dung bài viết (1–2 câu)..."></textarea>
        </div>

        <div style="margin-bottom:20px;">
            <label class="editor-label">Nội dung *</label>
            <textarea class="editor-input" id="artContent"
                placeholder="Viết nội dung bài viết đầy đủ tại đây..."></textarea>
        </div>

        <div class="editor-footer">
            <button onclick="closeEditor()"
                style="flex:1;height:40px;background:#f5f5f5;color:#555;border:none;border-radius:9px;font-size:13px;cursor:pointer;font-family:'DM Sans',sans-serif;">Huỷ</button>
            <button id="saveDraftBtn" onclick="saveArticle(false)"
                style="flex:1;height:40px;background:#e2e3e5;color:#383d41;border:none;border-radius:9px;font-size:13px;font-weight:500;cursor:pointer;font-family:'DM Sans',sans-serif;">Lưu nháp</button>
            <button id="savePublishBtn" onclick="saveArticle(true)"
                style="flex:2;height:40px;background:#0a4d7c;color:#fff;border:none;border-radius:9px;font-size:13px;font-weight:500;cursor:pointer;font-family:'DM Sans',sans-serif;">Đăng bài</button>
        </div>
    </div>
</div>


<!-- ── Modal Phiếu Khám Bệnh (chỉ bác sĩ) ────────────────────── -->
<div class="phieu-modal-overlay" id="phieuModal" onclick="if(event.target===this)closePhieu()">
    <div style="width:100%;max-width:680px;">
        <div class="phieu-controls">
