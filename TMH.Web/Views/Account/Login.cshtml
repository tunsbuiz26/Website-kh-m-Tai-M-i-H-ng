@model TMH.Shared.DTOs.LoginDto
@{
    ViewBag.Title = "Đăng nhập — Phòng Khám Tai Mũi Họng";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
.auth-wrap{display:flex;min-height:calc(100vh - 64px);align-items:center;justify-content:center;background:linear-gradient(135deg,#f0f8ff 0%,#fff 60%);padding:40px 20px;}
.auth-card{display:flex;width:100%;max-width:860px;border-radius:16px;border:1px solid #d4e8f5;overflow:hidden;background:#fff;box-shadow:0 8px 40px rgba(10,77,124,0.08);}
.auth-left{width:42%;background:#0a4d7c;padding:44px 36px;display:flex;flex-direction:column;justify-content:space-between;position:relative;overflow:hidden;}
.auth-left::before{content:'✚';position:absolute;bottom:60px;right:30px;font-size:120px;color:rgba(255,255,255,0.06);line-height:1;}
.al-brand{display:flex;align-items:center;gap:10px;position:relative;z-index:1;}
.al-icon{width:34px;height:34px;border-radius:9px;background:rgba(255,255,255,0.15);border:1px solid rgba(255,255,255,0.2);display:flex;align-items:center;justify-content:center;}
.al-name{font-family:'Crimson Pro',serif;font-size:16px;font-weight:600;color:#fff;}
.al-name span{color:#c9a227;}
.al-content{position:relative;z-index:1;}
.al-title{font-family:'Crimson Pro',serif;font-size:26px;font-weight:600;color:#fff;margin-bottom:10px;line-height:1.3;}
.al-sub{font-size:13px;color:rgba(255,255,255,0.65);line-height:1.65;margin-bottom:28px;}
.al-feat{display:flex;flex-direction:column;gap:12px;}
.feat-row{display:flex;align-items:center;gap:10px;}
.feat-dot{width:22px;height:22px;border-radius:50%;background:rgba(201,162,39,0.25);border:1px solid rgba(201,162,39,0.5);display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.feat-txt{font-size:12px;color:rgba(255,255,255,0.75);}
.al-footer{font-size:11px;color:rgba(255,255,255,0.4);position:relative;z-index:1;}
.al-footer a{color:#c9a227;}

.auth-right{flex:1;padding:44px 40px;display:flex;flex-direction:column;justify-content:center;}
.form-eyebrow{font-size:11px;font-weight:500;color:#c9a227;text-transform:uppercase;letter-spacing:.08em;margin-bottom:8px;}
.form-heading{font-family:'Crimson Pro',serif;font-size:24px;font-weight:600;color:#0a4d7c;margin-bottom:4px;}
.form-sub{font-size:13px;color:#7a9bb0;margin-bottom:24px;}
.role-tabs{display:flex;gap:0;background:#f0f8ff;border-radius:10px;padding:4px;margin-bottom:24px;}
.role-tab{flex:1;height:32px;border:none;background:transparent;font-size:12px;color:#7a9bb0;cursor:pointer;border-radius:7px;font-family:'DM Sans',sans-serif;font-weight:500;transition:background .15s,color .15s;}
.role-tab.active{background:#fff;color:#0a4d7c;box-shadow:0 1px 4px rgba(10,77,124,0.1);}
.form-group{margin-bottom:16px;}
.form-label{display:block;font-size:11px;font-weight:500;color:#3a5a72;margin-bottom:6px;text-transform:uppercase;letter-spacing:.05em;}
.input-wrap{position:relative;}
.form-control{width:100%;height:42px;border:1px solid #d4e8f5;border-radius:9px;padding:0 12px 0 40px;font-size:13px;color:#0d2d44;background:#fff;outline:none;font-family:'DM Sans',sans-serif;transition:border-color .15s;}
.form-control:focus{border-color:#1a6fa8;box-shadow:0 0 0 3px rgba(26,111,168,0.1);}
.input-icon{position:absolute;left:12px;top:50%;transform:translateY(-50%);}
.form-row-split{display:flex;justify-content:space-between;align-items:center;margin-bottom:20px;}
.check-lbl{display:flex;align-items:center;gap:6px;font-size:12px;color:#7a9bb0;cursor:pointer;}
.check-lbl input{accent-color:#1a6fa8;}
.forgot-link{font-size:12px;color:#1a6fa8;text-decoration:none;}
.btn-submit{width:100%;height:44px;background:#0a4d7c;color:#fff;border:none;border-radius:10px;font-size:14px;font-weight:500;cursor:pointer;font-family:'DM Sans',sans-serif;transition:background .15s;margin-bottom:16px;}
.btn-submit:hover{background:#1a6fa8;}
.divider{display:flex;align-items:center;gap:10px;margin-bottom:14px;}
.div-line{flex:1;height:1px;background:#d4e8f5;}
.div-text{font-size:11px;color:#7a9bb0;}
.btn-register-link{width:100%;height:40px;background:#fdf3d7;color:#c9a227;border:1px solid rgba(201,162,39,0.35);border-radius:10px;font-size:13px;font-weight:500;cursor:pointer;font-family:'DM Sans',sans-serif;transition:background .15s;text-align:center;display:flex;align-items:center;justify-content:center;text-decoration:none;}
.btn-register-link:hover{background:#f5e9b8;}
.validation-summary{background:#fcebeb;border:1px solid #f7c1c1;border-radius:9px;padding:12px 16px;margin-bottom:16px;font-size:13px;color:#a32d2d;}
.validation-summary ul{margin:0;padding-left:16px;}
</style>

<div class="auth-wrap">
    <div class="auth-card">
        <!-- Panel trái -->
        <div class="auth-left">
            <div class="al-brand">
                <div class="al-icon">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                        <path d="M8 2v12M2 8h12" stroke="#fff" stroke-width="2.2" stroke-linecap="round"/>
                    </svg>
                </div>
                <span class="al-name">Phòng Khám <span>TMH</span></span>
            </div>
            <div class="al-content">
                <div class="al-title">Cổng bệnh nhân<br>trực tuyến</div>
                <div class="al-sub">Quản lý lịch khám, xem kết quả xét nghiệm và trao đổi với bác sĩ mọi lúc, mọi nơi.</div>
                <div class="al-feat">
                    <div class="feat-row">
                        <div class="feat-dot"><svg width="10" height="10" viewBox="0 0 10 10" fill="none"><path d="M1.5 5l2.5 2.5L8.5 2.5" stroke="#c9a227" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></div>
                        <span class="feat-txt">Đặt & huỷ lịch khám trực tuyến 24/7</span>
                    </div>
                    <div class="feat-row">
                        <div class="feat-dot"><svg width="10" height="10" viewBox="0 0 10 10" fill="none"><path d="M1.5 5l2.5 2.5L8.5 2.5" stroke="#c9a227" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></div>
                        <span class="feat-txt">Nhận kết quả xét nghiệm ngay trên điện thoại</span>
                    </div>
                    <div class="feat-row">
                        <div class="feat-dot"><svg width="10" height="10" viewBox="0 0 10 10" fill="none"><path d="M1.5 5l2.5 2.5L8.5 2.5" stroke="#c9a227" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></div>
                        <span class="feat-txt">Hồ sơ bệnh án điện tử bảo mật tuyệt đối</span>
                    </div>
                </div>
            </div>
            <div class="al-footer">Bảo mật SSL · Mã hoá đầu cuối · <a asp-controller="Home" asp-action="HuongDan">Hướng dẫn sử dụng</a></div>
        </div>

        <!-- Panel phải: form -->
        <div class="auth-right">
            <div class="form-eyebrow">Chào mừng trở lại</div>
            <div class="form-heading">Đăng nhập hệ thống</div>
            <div class="form-sub">Vui lòng chọn loại tài khoản và nhập thông tin</div>

            <!-- Tab chọn loại tài khoản (thay đổi placeholder, không thay route) -->
            <div class="role-tabs">
                <button class="role-tab active" onclick="setTab(this,'bn')">👤 Bệnh nhân</button>
                <button class="role-tab"        onclick="setTab(this,'bs')">🩺 Bác sĩ / Nhân viên</button>
            </div>

            <!-- Validation summary từ ModelState -->
            @if (!ViewData.ModelState.IsValid)
            {
                <div class="validation-summary">
                    @Html.ValidationSummary(false, "", new { @class = "" })
                </div>
            }

            <form asp-action="Login" asp-controller="Account" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />

                <div class="form-group">
                    <label class="form-label" asp-for="UsernameOrEmail">Email / Số điện thoại</label>
                    <div class="input-wrap">
                        <span class="input-icon"><svg width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="6" r="3" stroke="#7a9bb0" stroke-width="1.3"/><path d="M2 14c0-3 2.7-5 6-5s6 2 6 5" stroke="#7a9bb0" stroke-width="1.3" stroke-linecap="round"/></svg></span>
                        <input asp-for="UsernameOrEmail" class="form-control" id="inp-user" placeholder="email@example.com hoặc 09xx..." />
                    </div>
                    <span asp-validation-for="UsernameOrEmail" class="field-error"></span>
                </div>

                <div class="form-group">
                    <label class="form-label" asp-for="Password">Mật khẩu</label>
                    <div class="input-wrap">
                        <span class="input-icon"><svg width="16" height="16" viewBox="0 0 16 16" fill="none"><rect x="3" y="7" width="10" height="7" rx="1.5" stroke="#7a9bb0" stroke-width="1.3"/><path d="M5 7V5a3 3 0 016 0v2" stroke="#7a9bb0" stroke-width="1.3" stroke-linecap="round"/></svg></span>
                        <input asp-for="Password" class="form-control" type="password" placeholder="••••••••" />
                    </div>
                    <span asp-validation-for="Password" class="field-error"></span>
                </div>

                <div class="form-row-split">
                    <label class="check-lbl">
                        <input asp-for="RememberMe" type="checkbox" /> Ghi nhớ đăng nhập
                    </label>
                    <a href="#" class="forgot-link">Quên mật khẩu?</a>
                </div>

                <button type="submit" class="btn-submit">Đăng nhập →</button>
            </form>

            <div class="divider"><div class="div-line"></div><span class="div-text">chưa có tài khoản?</span><div class="div-line"></div></div>
            <a asp-controller="Account" asp-action="Register" class="btn-register-link">✦ Tạo tài khoản bệnh nhân miễn phí</a>
        </div>
    </div>
</div>

<script>
function setTab(btn, role) {
    document.querySelectorAll('.role-tab').forEach(t => t.classList.remove('active'));
    btn.classList.add('active');
    document.getElementById('inp-user').placeholder =
        role === 'bn' ? 'email@example.com hoặc 09xx...' : 'Mã nhân viên / Email nội bộ';
}
</script>
