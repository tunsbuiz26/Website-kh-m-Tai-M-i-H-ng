@{
    ViewBag.Title = "Không có quyền truy cập";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div style="text-align:center;padding:80px 40px;">
    <div style="font-size:64px;margin-bottom:16px;">🔒</div>
    <h2 style="font-family:'Crimson Pro',serif;font-size:28px;color:#0a4d7c;margin-bottom:10px;">Không có quyền truy cập</h2>
    <p style="color:#7a9bb0;margin-bottom:28px;">Bạn không có quyền vào trang này. Vui lòng đăng nhập bằng tài khoản phù hợp.</p>
    <a asp-controller="Account" asp-action="Login"
       style="display:inline-block;padding:0 24px;height:42px;line-height:42px;background:#0a4d7c;color:#fff;border-radius:10px;text-decoration:none;font-size:14px;font-weight:500;">
        Đăng nhập lại
    </a>
</div>
