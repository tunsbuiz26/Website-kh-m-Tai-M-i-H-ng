{
  "ConnectionStrings": {
    // Thay YourServerName bằng tên SQL Server instance của bạn (vd: .\\SQLEXPRESS hoặc localhost)
    // Thay TMH_DB bằng tên database bạn muốn tạo
    "DefaultConnection": "Data Source=.\\SQLEXPRESS;Initial Catalog=TMH_DB;Integrated Security=True;Trust Server Certificate=True"
  },

  "JwtSettings": {
    // SecretKey: khóa bí mật ký JWT — tối thiểu 32 ký tự, đổi ngay khi deploy production
    // KHÔNG commit key thật lên Git — dùng Environment Variable hoặc Azure Key Vault
    "SecretKey": "TMH_SuperSecret_Key_2026!@#$_PleaseChange",
    "Issuer": "TMH.API",
    "Audience": "TMH.WebApp",
    // Token hết hạn sau 8 giờ — bệnh nhân đăng nhập sáng, chiều vẫn còn phiên làm việc
    "ExpireHours": "8"
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Information"
    }
  },
  "AllowedHosts": "*"
}
